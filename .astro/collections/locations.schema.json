{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "fullName": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "availability": {
      "type": "string",
      "enum": [
        "available",
        "full"
      ]
    },
    "availableUnits": {
      "default": "",
      "type": "string"
    },
    "image": {
      "default": "",
      "type": "string"
    },
    "seo": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description"
      ],
      "additionalProperties": false
    },
    "specs": {
      "type": "object",
      "properties": {
        "ceilingHeight": {
          "type": "string"
        },
        "power": {
          "type": "string"
        },
        "doorSize": {
          "type": "string"
        },
        "hvac": {
          "type": "string"
        },
        "suiteRange": {
          "type": "string"
        }
      },
      "required": [
        "ceilingHeight",
        "power",
        "doorSize",
        "hvac",
        "suiteRange"
      ],
      "additionalProperties": false
    },
    "mapEmbedUrl": {
      "type": "string"
    },
    "localGuide": {
      "type": "object",
      "properties": {
        "heading": {
          "type": "string"
        },
        "nearbyHighways": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "airport": {
          "type": "string"
        },
        "submarkets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "demandDrivers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "heading",
        "nearbyHighways",
        "airport",
        "submarkets",
        "demandDrivers"
      ],
      "additionalProperties": false
    },
    "tenantProfiles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "description"
        ],
        "additionalProperties": false
      }
    },
    "faq": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string"
          },
          "answer": {
            "type": "string"
          }
        },
        "required": [
          "question",
          "answer"
        ],
        "additionalProperties": false
      }
    },
    "schema": {
      "type": "object",
      "properties": {
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string"
            },
            "city": {
              "type": "string"
            },
            "state": {
              "type": "string"
            },
            "zip": {
              "type": "string"
            }
          },
          "required": [
            "street",
            "city",
            "state",
            "zip"
          ],
          "additionalProperties": false
        },
        "geo": {
          "type": "object",
          "properties": {
            "lat": {
              "type": "number"
            },
            "lng": {
              "type": "number"
            }
          },
          "required": [
            "lat",
            "lng"
          ],
          "additionalProperties": false
        },
        "phone": {
          "type": "string"
        }
      },
      "required": [
        "address",
        "geo",
        "phone"
      ],
      "additionalProperties": false
    },
    "tagline": {
      "default": "",
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "state",
    "fullName",
    "slug",
    "availability",
    "availableUnits",
    "image",
    "seo",
    "specs",
    "mapEmbedUrl",
    "localGuide",
    "tenantProfiles",
    "faq",
    "schema",
    "tagline"
  ],
  "additionalProperties": false
}