---
interface Props {
  headline: string;
  subheadline?: string;
  ctaButtons?: { label: string; href: string; variant?: 'primary' | 'white' }[];
  gradient?: string;
  layout?: 'center' | 'split';
}

const {
  headline,
  subheadline,
  ctaButtons = [],
  gradient = 'linear-gradient(135deg, #1B2A4A 0%, #243556 50%, #0F1A2E 100%)',
  layout = 'center',
} = Astro.props;

const isSplit = layout === 'split';
---

<section class:list={['hero', { 'hero--split': isSplit }]} style={`background: ${gradient};`}>
  <div class="hero-overlay"></div>
  <div class:list={['container', 'hero-container', { 'hero-container--split': isSplit }]}>
    <div class="hero-copy">
      <h1 class="hero-headline">{headline}</h1>
      {subheadline && <p class="hero-subheadline">{subheadline}</p>}
      {ctaButtons.length > 0 && !isSplit && (
        <div class="hero-ctas">
          {ctaButtons.map(btn => (
            <a
              href={btn.href}
              class:list={['btn', 'btn-lg', btn.variant === 'white' ? 'btn-white' : 'btn-primary']}
            >
              {btn.label}
            </a>
          ))}
        </div>
      )}
      <slot name="copy" />
    </div>
    {isSplit && (
      <div class="hero-form-col">
        <slot />
      </div>
    )}
    {!isSplit && <slot />}
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: var(--space-16) 0;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .hero {
      padding: var(--space-20) 0;
    }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(232, 98, 42, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(255, 255, 255, 0.03) 0%, transparent 50%);
    pointer-events: none;
  }

  .hero-container {
    position: relative;
    z-index: 1;
  }

  /* Center layout (default) */
  .hero-container:not(.hero-container--split) {
    text-align: center;
    max-width: 800px;
  }

  .hero-container:not(.hero-container--split) .hero-subheadline {
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Split layout */
  .hero-container--split {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    align-items: center;
    max-width: 1200px;
  }

  @media (min-width: 1024px) {
    .hero-container--split {
      flex-direction: row;
      gap: var(--space-12);
      align-items: center;
    }

    .hero-container--split .hero-copy {
      flex: 1;
      min-width: 0;
    }

    .hero-container--split .hero-form-col {
      flex: 0 0 auto;
      width: 420px;
    }
  }

  .hero-headline {
    color: var(--white);
    margin-bottom: var(--space-4);
  }

  .hero-subheadline {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--font-size-lg);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  .hero-ctas {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
  }

  @media (min-width: 640px) {
    .hero-ctas {
      flex-direction: row;
      justify-content: center;
      gap: var(--space-4);
    }
  }

  /* Split layout copy adjustments */
  .hero-container--split .hero-ctas {
    justify-content: flex-start;
  }

  .hero-form-col {
    display: flex;
    justify-content: center;
  }

  /* Hero bullets (used via slots) */
  .hero-copy :global(.hero-bullets) {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--font-size-sm);
    font-weight: 600;
    margin-top: var(--space-2);
  }

  .hero-container:not(.hero-container--split) :global(.hero-bullets) {
    justify-content: center;
  }

  .hero-copy :global(.hero-bullets li) {
    position: relative;
    padding-left: var(--space-4);
  }

  .hero-copy :global(.hero-bullets li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 6px;
    height: 6px;
    background: var(--orange);
    border-radius: 50%;
  }
</style>
