---
import { getEntry } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const year = new Date().getFullYear();
const homepage = await getEntry('pages', 'homepage');
const logo = homepage?.data?.logo || '';
---

<footer class="border-t border-black/8 bg-[#f7f5f1]">
  <div class="mx-auto max-w-7xl px-6 py-12 lg:px-8 lg:py-16">
    <div class="grid gap-8 lg:grid-cols-[1.5fr_1fr_1fr_1fr]">
      <!-- Brand -->
      <div>
        <a href={base} class="flex items-center gap-3 no-underline" aria-label="FlexSpace Home">
          {logo ? (
            <img src={logo} alt="FlexSpace" class="h-8 w-auto max-w-[160px] object-contain" />
          ) : (
            <>
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-black/10 bg-white">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 8.35V20a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8.35A2 2 0 0 1 3.26 6.5l8-3.2a2 2 0 0 1 1.48 0l8 3.2A2 2 0 0 1 22 8.35Z"/><path d="M6 18h12"/><path d="M6 14h12"/><rect width="12" height="12" x="6" y="10"/></svg>
              </div>
              <span class="text-sm font-semibold tracking-[0.12em] uppercase text-[#111]">FlexSpace</span>
            </>
          )}
        </a>
        <p class="mt-4 max-w-xs text-sm leading-6 text-black/55">
          Small-bay flex industrial space for lease in North Carolina and South Carolina. 1,000–3,000 SF suites built for contractors, e-commerce, light industrial, and growing businesses.
        </p>
      </div>

      <!-- Locations -->
      <div>
        <div class="text-xs font-semibold uppercase tracking-[0.14em] text-black/45 mb-4">Locations</div>
        <ul class="space-y-3 list-none p-0 m-0">
          <li><a href={`${base}locations/durham-nc/`} class="text-sm text-black/60 no-underline hover:text-black transition">Durham, NC</a></li>
          <li><a href={`${base}locations/asheville-nc/`} class="text-sm text-black/60 no-underline hover:text-black transition">Asheville, NC</a></li>
          <li><a href={`${base}locations/columbia-sc/`} class="text-sm text-black/60 no-underline hover:text-black transition">Columbia, SC</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <div class="text-xs font-semibold uppercase tracking-[0.14em] text-black/45 mb-4">Company</div>
        <ul class="space-y-3 list-none p-0 m-0">
          <li><a href={`${base}about/`} class="text-sm text-black/60 no-underline hover:text-black transition">About</a></li>
          <li><a href={`${base}blog/`} class="text-sm text-black/60 no-underline hover:text-black transition">Blog</a></li>
          <li><a href={`${base}faq/`} class="text-sm text-black/60 no-underline hover:text-black transition">FAQ</a></li>
          <li><a href={`${base}contact/`} class="text-sm text-black/60 no-underline hover:text-black transition">Contact</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <div class="text-xs font-semibold uppercase tracking-[0.14em] text-black/45 mb-4">Contact</div>
        <ul class="space-y-3 list-none p-0 m-0">
          <li><a href="tel:+18285551234" class="text-sm text-black/60 no-underline hover:text-black transition">(828) 555-1234</a></li>
          <li><a href="mailto:leasing@getflexspace.com" class="text-sm text-black/60 no-underline hover:text-black transition">leasing@getflexspace.com</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-black/8 pt-6">
      <p class="text-xs text-black/40 text-center">&copy; {year} FlexSpace. All rights reserved.</p>
    </div>
  </div>
</footer>
