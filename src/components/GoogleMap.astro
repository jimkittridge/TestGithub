---
interface Props {
  embedUrl: string;
  title: string;
}

const { embedUrl, title } = Astro.props;
---

<section class="section map-section">
  <div class="container">
    <h2 class="text-center">Location</h2>
    <div class="map-wrapper">
      <iframe
        src={embedUrl}
        title={`Map of ${title}`}
        width="100%"
        height="100%"
        style="border: 0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </div>
</section>

<style>
  .map-section h2 {
    margin-bottom: var(--space-6);
  }

  .map-wrapper {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    background: var(--light-grey);
  }

  .map-wrapper iframe {
    width: 100%;
    height: 100%;
  }

  @media (max-width: 639px) {
    .map-wrapper {
      aspect-ratio: 4 / 3;
    }
  }
</style>
