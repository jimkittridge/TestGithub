---
interface Props {
  cityName?: string;
}

const { cityName } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const heading = cityName ? `${cityName} Property` : 'Our Properties';

const images = [
  { src: `${base}images/exterior-closeup.jpg`, alt: 'Small bay flex space suite with roll-up door and glass entry' },
  { src: `${base}images/exterior-angle.jpg`, alt: 'Flex space building exterior showing brick construction and drive-in access' },
  { src: `${base}images/exterior-wide.jpg`, alt: 'Multiple flex space bays with individual roll-up doors and parking' },
  { src: `${base}images/exterior-front.jpg`, alt: 'Front view of industrial flex space building with tenant signage' },
  { src: `${base}images/exterior-full.jpg`, alt: 'Full flex space property showing all bays with dedicated parking' },
];
---

<section class="section gallery-section">
  <div class="container">
    <h2 class="text-center" style="margin-bottom: var(--space-2);">{heading}</h2>
    <p class="text-center text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-8);">
      Brick-and-metal construction with individual drive-in doors, glass entries, and dedicated parking for every suite.
    </p>
    <div class="gallery-grid">
      <div class="gallery-featured">
        <img src={images[0].src} alt={images[0].alt} loading="lazy" width="800" height="534" />
      </div>
      <div class="gallery-thumb">
        <img src={images[1].src} alt={images[1].alt} loading="lazy" width="400" height="267" />
      </div>
      <div class="gallery-thumb">
        <img src={images[2].src} alt={images[2].alt} loading="lazy" width="400" height="267" />
      </div>
      <div class="gallery-thumb">
        <img src={images[3].src} alt={images[3].alt} loading="lazy" width="400" height="267" />
      </div>
      <div class="gallery-thumb">
        <img src={images[4].src} alt={images[4].alt} loading="lazy" width="400" height="267" />
      </div>
    </div>
  </div>
</section>

<style>
  .gallery-section {
    background: var(--light-grey);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    max-width: 1000px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
    }

    .gallery-featured {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .gallery-featured {
      grid-column: 1 / 3;
      grid-row: 1 / 3;
    }
  }

  .gallery-featured img,
  .gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-lg);
    display: block;
  }

  .gallery-featured img {
    aspect-ratio: 3 / 2;
  }

  .gallery-thumb img {
    aspect-ratio: 3 / 2;
  }

  @media (min-width: 1024px) {
    .gallery-featured img {
      aspect-ratio: auto;
      min-height: 100%;
    }
  }
</style>
