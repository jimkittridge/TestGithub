---
const tenantTypes = [
  { name: 'HVAC & Mechanical', icon: 'wrench' },
  { name: 'E-Commerce', icon: 'package' },
  { name: 'Craft Brewing', icon: 'beer' },
  { name: 'Fitness & CrossFit', icon: 'fitness' },
  { name: 'Creative Studios', icon: 'palette' },
  { name: 'Contractors', icon: 'hammer' },
];
---

<section class="section social-proof">
  <div class="container">
    <p class="proof-label text-center">Trusted by businesses like yours</p>
    <div class="tenant-grid">
      {tenantTypes.map(tenant => (
        <div class="tenant-item">
          <div class="tenant-icon">
            {tenant.icon === 'wrench' && (
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M21 7a5 5 0 00-7.07 0L7 14l7 7 6.93-6.93A5 5 0 0021 7z"/>
                <path d="M4 24l3-3"/>
              </svg>
            )}
            {tenant.icon === 'package' && (
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="4" y="8" width="20" height="16" rx="2"/>
                <path d="M4 12h20M14 8v16M10 4h8l2 4H8l2-4z"/>
              </svg>
            )}
            {tenant.icon === 'beer' && (
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="6" y="6" width="12" height="18" rx="2"/>
                <path d="M18 10h3a2 2 0 012 2v4a2 2 0 01-2 2h-3"/>
                <path d="M10 12v6M14 12v6"/>
              </svg>
            )}
            {tenant.icon === 'fitness' && (
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 14h20M8 10v8M20 10v8M6 11v6M22 11v6"/>
              </svg>
            )}
            {tenant.icon === 'palette' && (
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="14" cy="14" r="10"/>
                <circle cx="10" cy="11" r="1.5" fill="currentColor"/>
                <circle cx="17" cy="10" r="1.5" fill="currentColor"/>
                <circle cx="10" cy="17" r="1.5" fill="currentColor"/>
                <path d="M18 16a2 2 0 01-2 2h-1a1 1 0 00-1 1v1"/>
              </svg>
            )}
            {tenant.icon === 'hammer' && (
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14 4v8l-4 4M14 12l4 4"/>
                <rect x="4" y="18" width="6" height="6" rx="1" transform="rotate(-45 4 18)"/>
              </svg>
            )}
          </div>
          <span class="tenant-name">{tenant.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .proof-label {
    font-size: var(--font-size-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--slate);
    margin-bottom: var(--space-8);
  }

  .tenant-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .tenant-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .tenant-grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .tenant-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4);
    border-radius: var(--radius-md);
    transition: background 0.2s ease;
  }

  .tenant-item:hover {
    background: var(--light-grey);
  }

  .tenant-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--navy);
    opacity: 0.5;
  }

  .tenant-name {
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--slate);
    text-align: center;
  }
</style>
