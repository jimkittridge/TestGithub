---
import { getEntry } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const year = new Date().getFullYear();
const homepage = await getEntry('pages', 'homepage');
const logo = homepage?.data?.logo || `${base}images/logo.png`;
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col">
        <a href={base} class="footer-logo" aria-label="GetFlexSpace Home">
          <img src={logo} alt="GetFlexSpace" class="footer-logo-img" />
        </a>
        <p class="footer-desc">Small bay flex space for lease in the Carolinas. 1,000–3,000 SF suites built for contractors, e-commerce, light industrial, and growing businesses.</p>
      </div>

      <div class="footer-col">
        <h4 class="footer-heading">Locations</h4>
        <ul class="footer-links">
          <li><a href={`${base}locations/asheville-nc/`}>Flex Space in Asheville, NC</a></li>
          <li><a href={`${base}locations/durham-nc/`}>Flex Space in Durham, NC</a></li>
          <li><a href={`${base}locations/columbia-sc/`}>Flex Space in Columbia, SC</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-heading">Company</h4>
        <ul class="footer-links">
          <li><a href={`${base}about/`}>About Us</a></li>
          <li><a href={`${base}faq/`}>FAQ</a></li>
          <li><a href={`${base}contact/`}>Contact</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-heading">Contact</h4>
        <ul class="footer-links">
          <li>
            <a href="tel:+18285551234">(828) 555-1234</a>
          </li>
          <li>
            <a href="mailto:leasing@getflexspace.com">leasing@getflexspace.com</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} GetFlexSpace. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--dark);
    color: rgba(255, 255, 255, 0.7);
    padding: var(--space-12) 0 var(--space-6);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--white);
    font-weight: 800;
    font-size: var(--font-size-lg);
    text-decoration: none;
    margin-bottom: var(--space-3);
  }

  .footer-logo:hover {
    color: var(--orange);
  }

  .footer-logo-img {
    height: 28px;
    width: auto;
    max-width: 180px;
    object-fit: contain;
  }

  .footer-desc {
    font-size: var(--font-size-sm);
    line-height: 1.7;
  }

  .footer-heading {
    color: var(--white);
    font-size: var(--font-size-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-4);
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-links a {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--font-size-sm);
    text-decoration: none;
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }

  @media (min-width: 768px) {
    .footer-links a {
      min-height: auto;
    }
  }

  .footer-links a:hover {
    color: var(--orange);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: var(--space-6);
    font-size: var(--font-size-xs);
    text-align: center;
  }
</style>
