---
interface Props {
  availability: 'available' | 'full';
  availableUnits?: string;
  cityName?: string;
}

const { availability, availableUnits, cityName } = Astro.props;
const locationName = cityName || 'this location';
---

<div class:list={['availability-banner', availability === 'available' ? 'available' : 'full']}>
  <div class="container banner-content">
    <span class="status-dot"></span>
    {availability === 'available' ? (
      <div>
        <span class="status-label">Space Available</span>
        {availableUnits && <span class="status-detail">{availableUnits}</span>}
      </div>
    ) : (
      <div>
        <span class="status-label">Suites lease quickly in {locationName}.</span>
        <span class="status-detail">Tell us your size, use, and timing, and we'll send current matches and upcoming openings.</span>
      </div>
    )}
  </div>
</div>

<style>
  .availability-banner {
    padding: var(--space-4) 0;
    font-weight: 600;
  }

  .availability-banner.available {
    background: rgba(16, 185, 129, 0.08);
    border-bottom: 2px solid #10B981;
  }

  .availability-banner.full {
    background: rgba(245, 158, 11, 0.08);
    border-bottom: 2px solid #F59E0B;
  }

  .banner-content {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .status-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .available .status-dot {
    background: #10B981;
    box-shadow: 0 0 8px rgba(16, 185, 129, 0.4);
  }

  .full .status-dot {
    background: #F59E0B;
    box-shadow: 0 0 8px rgba(245, 158, 11, 0.4);
  }

  .status-label {
    display: block;
    font-size: var(--font-size-base);
    color: var(--navy);
  }

  .status-detail {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--slate);
    font-weight: 400;
  }
</style>
