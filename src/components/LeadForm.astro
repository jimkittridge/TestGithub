---
interface Props {
  compact?: boolean;
  layout?: 'stacked' | 'inline';
  buttonLabel?: string;
}

const { compact = false, layout = 'stacked', buttonLabel = 'Get availability' } = Astro.props;
---

{layout === 'inline' ? (
  <div>
    <form name="lead-inline" method="POST" data-netlify="true" class="grid gap-3 lg:grid-cols-[1fr_1fr_1fr_auto]">
      <input type="hidden" name="form-name" value="lead-inline" />
      <input
        type="text"
        name="name"
        required
        class="h-12 rounded-2xl border border-black/10 bg-white px-4 text-black placeholder:text-black/35 focus:outline-none focus:ring-2 focus:ring-black/20"
        placeholder="Your name"
      />
      <input
        type="text"
        name="business"
        required
        class="h-12 rounded-2xl border border-black/10 bg-white px-4 text-black placeholder:text-black/35 focus:outline-none focus:ring-2 focus:ring-black/20"
        placeholder="Website or business name"
      />
      <input
        type="tel"
        name="phone"
        required
        class="h-12 rounded-2xl border border-black/10 bg-white px-4 text-black placeholder:text-black/35 focus:outline-none focus:ring-2 focus:ring-black/20"
        placeholder="Cell phone number"
      />
      <button type="submit" class="h-12 rounded-2xl bg-black px-6 text-white font-medium hover:bg-black/85 transition cursor-pointer lg:min-w-[180px]">
        {buttonLabel}
      </button>
    </form>
    <p class="mt-3 text-sm leading-6 text-black/52">
      Tell us who you are and how to reach you. We can follow up with availability, pricing, and next steps.
    </p>
  </div>
) : (
  <form name="lead-stacked" method="POST" data-netlify="true" class={compact ? 'grid gap-3' : 'grid gap-4'}>
    <input type="hidden" name="form-name" value="lead-stacked" />
    <input
      type="text"
      name="name"
      required
      class="h-12 rounded-2xl border border-black/10 bg-[#fbfaf8] px-4 text-black placeholder:text-black/35 focus:outline-none focus:ring-2 focus:ring-black/20"
      placeholder="Your name"
    />
    <input
      type="text"
      name="business"
      required
      class="h-12 rounded-2xl border border-black/10 bg-[#fbfaf8] px-4 text-black placeholder:text-black/35 focus:outline-none focus:ring-2 focus:ring-black/20"
      placeholder="Website or business name"
    />
    <input
      type="tel"
      name="phone"
      required
      class="h-12 rounded-2xl border border-black/10 bg-[#fbfaf8] px-4 text-black placeholder:text-black/35 focus:outline-none focus:ring-2 focus:ring-black/20"
      placeholder="Cell phone number"
    />
    <button type="submit" class="h-12 rounded-2xl bg-black px-6 text-white font-medium hover:bg-black/85 transition cursor-pointer">
      {buttonLabel}
    </button>
    <p class="text-sm leading-6 text-black/52">
      Tell us who you are and how to reach you. We can follow up with availability, pricing, and next steps.
    </p>
  </form>
)}
