---
import type { CityData } from '../data/cities';

interface Props {
  type: 'Organization' | 'LocalBusiness' | 'FAQPage';
  city?: CityData;
  faqItems?: { question: string; answer: string }[];
}

const { type, city, faqItems } = Astro.props;

function buildSchema() {
  if (type === 'Organization') {
    return {
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'GetFlexSpace',
      url: 'https://getflexspace.com',
      logo: 'https://getflexspace.com/favicon.svg',
      description: 'Premium small bay flex space for lease in the Carolinas. 1,000–3,000 sq ft suites for contractors, e-commerce, and creative businesses.',
      contactPoint: {
        '@type': 'ContactPoint',
        telephone: '+18285551234',
        contactType: 'leasing',
      },
      areaServed: [
        { '@type': 'City', name: 'Asheville', containedInPlace: { '@type': 'State', name: 'North Carolina' } },
        { '@type': 'City', name: 'Durham', containedInPlace: { '@type': 'State', name: 'North Carolina' } },
        { '@type': 'City', name: 'Columbia', containedInPlace: { '@type': 'State', name: 'South Carolina' } },
      ],
    };
  }

  if (type === 'LocalBusiness' && city) {
    return [
      {
        '@context': 'https://schema.org',
        '@type': 'LocalBusiness',
        '@id': `https://getflexspace.com/${city.slug}/`,
        name: `GetFlexSpace ${city.fullName}`,
        description: city.seo.description,
        url: `https://getflexspace.com/${city.slug}/`,
        telephone: city.schema.phone,
        address: {
          '@type': 'PostalAddress',
          streetAddress: city.schema.address.street,
          addressLocality: city.schema.address.city,
          addressRegion: city.schema.address.state,
          postalCode: city.schema.address.zip,
          addressCountry: 'US',
        },
        geo: {
          '@type': 'GeoCoordinates',
          latitude: city.schema.geo.lat,
          longitude: city.schema.geo.lng,
        },
        openingHoursSpecification: {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
          opens: '00:00',
          closes: '23:59',
        },
      },
      {
        '@context': 'https://schema.org',
        '@type': 'RealEstateListing',
        name: `Flex Space for Lease in ${city.fullName}`,
        description: city.seo.description,
        url: `https://getflexspace.com/${city.slug}/`,
        about: {
          '@type': 'Place',
          name: `GetFlexSpace ${city.fullName}`,
          address: {
            '@type': 'PostalAddress',
            addressLocality: city.schema.address.city,
            addressRegion: city.schema.address.state,
            postalCode: city.schema.address.zip,
          },
        },
      },
    ];
  }

  if (type === 'FAQPage' && faqItems) {
    return {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqItems.map(item => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    };
  }

  return null;
}

const schema = buildSchema();
const schemaJson = schema ? JSON.stringify(schema) : null;
---

{schemaJson && <Fragment set:html={`<script type="application/ld+json">${schemaJson}</script>`} />}
