---
interface Props {
  headline: string;
  subheadline?: string;
  layout?: 'center' | 'split';
  backgroundImage?: string;
}

const {
  headline,
  subheadline,
  layout = 'center',
  backgroundImage,
} = Astro.props;

const isSplit = layout === 'split';
---

<section class:list={['hero-new', { 'hero-new--split': isSplit }]}>
  {backgroundImage && (
    <div class="absolute inset-0">
      <img src={backgroundImage} alt="" class="h-full w-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-black/55"></div>
    </div>
  )}
  {!backgroundImage && <div class="absolute inset-0 bg-black"></div>}

  <div class:list={['hero-new__inner', { 'hero-new__inner--split': isSplit }]}>
    <div class="hero-new__copy">
      <h1 class="hero-new__headline">{headline}</h1>
      {subheadline && <p class="hero-new__sub">{subheadline}</p>}
      <slot name="copy" />
    </div>
    {isSplit && (
      <div class="hero-new__form-col">
        <slot />
      </div>
    )}
    {!isSplit && <slot />}
  </div>
  <div class="hero-new__bottom">
    <slot name="bottom" />
  </div>
</section>

<style>
  .hero-new {
    position: relative;
    overflow: hidden;
    padding: 4rem 0;
  }

  @media (min-width: 768px) {
    .hero-new {
      padding: 5rem 0;
    }
  }

  .hero-new__inner {
    position: relative;
    z-index: 1;
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 1024px) {
    .hero-new__inner {
      padding: 0 2rem;
    }
  }

  /* Center layout */
  .hero-new__inner:not(.hero-new__inner--split) {
    text-align: center;
    max-width: 50rem;
  }

  .hero-new__inner:not(.hero-new__inner--split) .hero-new__sub {
    max-width: 37rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* Split layout */
  .hero-new__inner--split {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-new__inner--split {
      flex-direction: row;
      gap: 3rem;
      align-items: center;
    }

    .hero-new__inner--split .hero-new__copy {
      flex: 1;
      min-width: 0;
    }

    .hero-new__inner--split .hero-new__form-col {
      flex: 0 0 auto;
      width: 420px;
    }
  }

  .hero-new__headline {
    color: white;
    font-size: clamp(2rem, 1.4rem + 3vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }

  .hero-new__sub {
    color: rgba(255, 255, 255, 0.8);
    font-size: clamp(1rem, 0.9rem + 0.5vw, 1.25rem);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  /* Hero bullets via slot */
  .hero-new__copy :global(.hero-bullets) {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.875rem;
    font-weight: 500;
    margin-top: 0.5rem;
    padding: 0;
  }

  .hero-new__inner:not(.hero-new__inner--split) :global(.hero-bullets) {
    justify-content: center;
  }

  .hero-new__copy :global(.hero-bullets li) {
    position: relative;
    padding-left: 1rem;
  }

  .hero-new__copy :global(.hero-bullets li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 6px;
    height: 6px;
    background: white;
    border-radius: 50%;
    opacity: 0.5;
  }

  .hero-new__form-col {
    display: flex;
    justify-content: center;
  }

  .hero-new__bottom {
    position: relative;
    z-index: 1;
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 1024px) {
    .hero-new__bottom {
      padding: 0 2rem;
    }
  }

  .hero-new__bottom:empty {
    display: none;
  }
</style>
