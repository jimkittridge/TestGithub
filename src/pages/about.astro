---
import NewLayout from '../layouts/NewLayout.astro';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'about');
const cms = page!.data;
const { Content } = await render(page!);
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<NewLayout title={cms.seo.title} description={cms.seo.description}>

  <!-- Breadcrumb -->
  <div class="border-b border-black/5 bg-[#f7f5f1]">
    <div class="mx-auto max-w-7xl px-6 py-3 lg:px-8">
      <nav class="flex items-center gap-2 text-sm text-black/45">
        <a href={base} class="text-black/45 no-underline transition hover:text-black">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span class="font-medium text-black/70">About</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="text-sm uppercase tracking-[0.16em] text-black/45">About us</div>
        <h1 class="mt-3 text-5xl font-semibold tracking-[-0.03em] text-[#111] sm:text-6xl" style="color: #111;">
          {cms.hero!.headline}
        </h1>
        <p class="mt-6 text-xl leading-8 text-black/64">
          {cms.hero!.subheadline}
        </p>
      </div>
    </div>
  </section>

  <!-- Hero Image -->
  {cms.heroImage && (
    <section class="pb-12">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="overflow-hidden rounded-[28px] border border-black/10 shadow-[0_18px_50px_rgba(0,0,0,0.06)]">
          <img
            src={`${base}${cms.heroImage.replace(/^\//, '')}`}
            alt="GetFlexSpace locations across the Carolinas"
            class="block w-full object-cover"
            style="aspect-ratio: 2.5 / 1;"
            width="1000"
            height="400"
          />
        </div>
      </div>
    </section>
  )}

  <!-- Our Story -->
  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl about-prose">
        <Content />
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="text-center">
        <div class="text-sm uppercase tracking-[0.16em] text-black/45">Why FlexSpace</div>
        <h2 class="mt-3 text-3xl font-semibold tracking-[-0.03em] text-[#111] sm:text-4xl">What Sets Us Apart</h2>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2">
        {cms.values!.map(v => (
          <div class="rounded-[24px] border border-black/8 bg-white p-7 shadow-[0_10px_24px_rgba(0,0,0,0.03)] transition hover:shadow-[0_15px_40px_rgba(0,0,0,0.06)]">
            <h3 class="text-lg font-semibold tracking-[-0.02em] text-[#111]">{v.title}</h3>
            <p class="mt-2 text-sm leading-7 text-black/60">{v.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="rounded-[28px] border border-black/10 bg-white p-10 text-center shadow-[0_18px_50px_rgba(0,0,0,0.06)] sm:p-14">
        <h2 class="text-3xl font-semibold tracking-[-0.03em] text-[#111] sm:text-4xl">{cms.cta!.heading}</h2>
        <p class="mx-auto mt-4 max-w-xl text-lg leading-8 text-black/60">{cms.cta!.subheading}</p>
        <a href={`${base}contact/`} class="mt-8 inline-block rounded-2xl bg-black px-8 py-3.5 text-sm font-medium text-white no-underline transition hover:bg-black/85">
          Get Availability & Pricing
        </a>
      </div>
    </div>
  </section>

</NewLayout>

<style>
  .about-prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: #111;
    margin-bottom: 0.75rem;
    margin-top: 2.5rem;
  }

  .about-prose :global(h2:first-child) {
    margin-top: 0;
  }

  .about-prose :global(p) {
    color: rgba(0, 0, 0, 0.6);
    font-size: 1rem;
    line-height: 1.85;
    margin-bottom: 1.25rem;
  }
</style>
