---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'about');
const cms = page!.data;
const { Content } = await render(page!);
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout title={cms.seo.title} description={cms.seo.description}>
  <Hero
    headline={cms.hero!.headline}
    subheadline={cms.hero!.subheadline}
  />

  <section class="section">
    <div class="container about-content">
      {cms.heroImage && (
        <div class="about-hero-img">
          <img src={`${base}${cms.heroImage.replace(/^\//, '')}`} alt="GetFlexSpace locations across the Carolinas" width="1000" height="400" />
        </div>
      )}

      <div class="about-prose"><Content /></div>

      <h2>What Sets Us Apart</h2>
      <div class="values-grid">
        {cms.values!.map(v => (
          <div class="value-card">
            <h3>{v.title}</h3>
            <p>{v.description}</p>
          </div>
        ))}
      </div>

      <div class="cta-block text-center">
        <h2>{cms.cta!.heading}</h2>
        <p class="text-slate">{cms.cta!.subheading}</p>
        <a href={`${base}contact/`} class="btn btn-primary btn-lg">Get Availability & Pricing</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-content {
    max-width: 800px;
  }

  .about-hero-img {
    margin-bottom: var(--space-10);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .about-hero-img img {
    width: 100%;
    aspect-ratio: 2.5 / 1;
    object-fit: cover;
    display: block;
  }

  .about-prose :global(h2) {
    margin-bottom: var(--space-4);
    margin-top: var(--space-10);
  }

  .about-prose :global(h2:first-child) {
    margin-top: 0;
  }

  .about-prose :global(p) {
    color: var(--slate);
    font-size: var(--font-size-base);
    line-height: 1.8;
    margin-bottom: var(--space-4);
  }

  .about-content > h2 {
    margin-bottom: var(--space-4);
    margin-top: var(--space-10);
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-top: var(--space-6);
  }

  @media (min-width: 640px) {
    .values-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .value-card {
    padding: var(--space-6);
    background: var(--light-grey);
    border-radius: var(--radius-lg);
  }

  .value-card h3 {
    font-size: var(--font-size-base);
    margin-bottom: var(--space-2);
  }

  .value-card p {
    color: var(--slate);
    font-size: var(--font-size-sm);
    line-height: 1.7;
  }

  .cta-block {
    margin-top: var(--space-12);
    padding: var(--space-10);
    background: var(--light-grey);
    border-radius: var(--radius-lg);
  }

  .cta-block h2 {
    margin-top: 0;
    margin-bottom: var(--space-3);
  }

  .cta-block p {
    margin-bottom: var(--space-6);
    font-size: var(--font-size-lg);
  }
</style>
