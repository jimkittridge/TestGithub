---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const title = 'About GetFlexSpace | Small Bay Industrial Flex Space in the Carolinas';
const description = 'GetFlexSpace provides premium small bay industrial flex space across the Carolinas. Learn about our mission to give small businesses the professional space they deserve.';
---

<BaseLayout title={title} description={description}>
  <Hero
    headline="Built for Small Business."
    subheadline="We believe every contractor, maker, and entrepreneur deserves a professional, well-managed space to grow."
  />

  <section class="section">
    <div class="container about-content">
      <div class="about-hero-img">
        <img src={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}images/exterior-full.svg`} alt="GetFlexSpace property — small bay flex space with roll-up doors and dedicated parking" loading="lazy" width="800" height="400" />
      </div>

      <h2>Our Story</h2>
      <p>
        GetFlexSpace was founded on a simple observation: small businesses in the Carolinas were being underserved by the commercial real estate market. Traditional warehouse leases required too much space, too much commitment, and came with too little flexibility.
      </p>
      <p>
        We set out to change that. Our small bay flex spaces—ranging from 1,000 to 3,000 square feet—are purpose-built for the businesses that power local economies: HVAC contractors, e-commerce operators, craft brewers, fitness studios, and creative professionals.
      </p>

      <h2>What Sets Us Apart</h2>
      <div class="values-grid">
        <div class="value-card">
          <h3>Right-Sized Spaces</h3>
          <p>No more leasing 10,000 sq ft when you only need 2,000. Our suites are designed for small businesses that need room to operate without the overhead of a massive warehouse.</p>
        </div>
        <div class="value-card">
          <h3>Professional Grade</h3>
          <p>High ceilings, drive-in doors, 3-phase power, and full HVAC. These aren't converted strip mall units—they're built from the ground up for industrial and flex use.</p>
        </div>
        <div class="value-card">
          <h3>Hands-On Management</h3>
          <p>Responsive maintenance, clean common areas, and a leasing team that actually picks up the phone. We treat our tenants like partners, not account numbers.</p>
        </div>
        <div class="value-card">
          <h3>Growing Footprint</h3>
          <p>With locations in Asheville, Durham, and Columbia, we're expanding across the Carolinas to meet the surging demand for small bay industrial space.</p>
        </div>
      </div>

      <div class="cta-block text-center">
        <h2>Ready to See a Space?</h2>
        <p class="text-slate">Get in touch to schedule a tour or check availability at any of our locations.</p>
        <a href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}contact/`} class="btn btn-primary btn-lg">Get Availability & Pricing</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-content {
    max-width: 800px;
  }

  .about-hero-img {
    margin-bottom: var(--space-10);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .about-hero-img img {
    width: 100%;
    aspect-ratio: 2.5 / 1;
    object-fit: cover;
    display: block;
  }

  .about-content h2 {
    margin-bottom: var(--space-4);
    margin-top: var(--space-10);
  }

  .about-content h2:first-of-type {
    margin-top: 0;
  }

  .about-content > p {
    color: var(--slate);
    font-size: var(--font-size-base);
    line-height: 1.8;
    margin-bottom: var(--space-4);
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-top: var(--space-6);
  }

  @media (min-width: 640px) {
    .values-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .value-card {
    padding: var(--space-6);
    background: var(--light-grey);
    border-radius: var(--radius-lg);
  }

  .value-card h3 {
    font-size: var(--font-size-base);
    margin-bottom: var(--space-2);
  }

  .value-card p {
    color: var(--slate);
    font-size: var(--font-size-sm);
    line-height: 1.7;
  }

  .cta-block {
    margin-top: var(--space-12);
    padding: var(--space-10);
    background: var(--light-grey);
    border-radius: var(--radius-lg);
  }

  .cta-block h2 {
    margin-top: 0;
    margin-bottom: var(--space-3);
  }

  .cta-block p {
    margin-bottom: var(--space-6);
    font-size: var(--font-size-lg);
  }
</style>
