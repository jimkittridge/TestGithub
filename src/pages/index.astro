---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import HeroForm from '../components/HeroForm.astro';
import CityCard from '../components/CityCard.astro';
import WhyUsSection from '../components/WhyUsSection.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { getCollection, getEntry } from 'astro:content';

const page = await getEntry('pages', 'homepage');
const cms = page!.data;
const allLocations = await getCollection('locations');

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const orgSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'GetFlexSpace',
  url: `https://jimkittridge.github.io/TestGithub/`,
  logo: `https://jimkittridge.github.io/TestGithub/favicon.svg`,
  description: cms.seo.description,
  contactPoint: { '@type': 'ContactPoint', telephone: '+18285551234', contactType: 'leasing' },
  areaServed: allLocations.map(loc => ({
    '@type': 'City',
    name: loc.data.name,
    containedInPlace: { '@type': 'State', name: loc.data.state === 'NC' ? 'North Carolina' : 'South Carolina' },
  })),
});

const useCases = cms.useCases!.items;
const homeFaq = cms.faq!;
---

<BaseLayout title={cms.seo.title} description={cms.seo.description} schemaMarkup={orgSchema}>
  <!-- Hero -->
  <Hero
    headline={cms.hero!.headline}
    subheadline={cms.hero!.subheadline}
    layout="split"
    backgroundImage={`${base}images/hero-bg.svg`}
  >
    <Fragment slot="copy">
      <ul class="hero-bullets">
        {cms.bullets?.map(b => <li>{b}</li>)}
      </ul>
    </Fragment>
    <HeroForm />
  </Hero>

  <!-- Three-Location Selector -->
  <section class="section">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: var(--space-2);">{cms.citySection!.heading}</h2>
      <p class="text-center text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-10);">{cms.citySection!.subheading}</p>
      <div class="grid grid-3">
        {allLocations.map(loc => (
          <CityCard
            name={loc.data.name}
            state={loc.data.state}
            slug={loc.data.slug}
            tagline={loc.data.tagline || ''}
            availability={loc.data.availability}
            specs={`${loc.data.specs.suiteRange} | ${loc.data.specs.ceilingHeight}`}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="section use-cases">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: var(--space-2);">{cms.useCases!.heading}</h2>
      <p class="text-center text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-10);">{cms.useCases!.subheading}</p>
      <div class="use-case-grid">
        {useCases.map(uc => (
          <div class="use-case-card">
            <div class="uc-icon">
              {uc.icon === 'hammer' && (
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 4v8l-4 4M14 12l4 4"/><rect x="4" y="18" width="6" height="6" rx="1" transform="rotate(-45 4 18)"/></svg>
              )}
              {uc.icon === 'package' && (
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="8" width="20" height="16" rx="2"/><path d="M4 12h20M14 8v16M10 4h8l2 4H8l2-4z"/></svg>
              )}
              {uc.icon === 'gear' && (
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="14" cy="14" r="4"/><path d="M14 2v4M14 22v4M4.93 4.93l2.83 2.83M20.24 20.24l2.83 2.83M2 14h4M22 14h4M4.93 23.07l2.83-2.83M20.24 7.76l2.83-2.83"/></svg>
              )}
              {uc.icon === 'beer' && (
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="6" y="6" width="12" height="18" rx="2"/><path d="M18 10h3a2 2 0 012 2v4a2 2 0 01-2 2h-3"/><path d="M10 12v6M14 12v6"/></svg>
              )}
              {uc.icon === 'palette' && (
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="14" cy="14" r="10"/><circle cx="10" cy="11" r="1.5" fill="currentColor"/><circle cx="17" cy="10" r="1.5" fill="currentColor"/><circle cx="10" cy="17" r="1.5" fill="currentColor"/><path d="M18 16a2 2 0 01-2 2h-1a1 1 0 00-1 1v1"/></svg>
              )}
              {uc.icon === 'briefcase' && (
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="10" width="22" height="14" rx="2"/><path d="M10 10V7a2 2 0 012-2h4a2 2 0 012 2v3"/><path d="M3 16h22"/></svg>
              )}
            </div>
            <h3>{uc.title}</h3>
            <p>{uc.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Property Highlights -->
  <section class="section property-highlights">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: var(--space-2);">{cms.highlights!.heading}</h2>
      <p class="text-center" style="font-size: var(--font-size-lg); margin-bottom: var(--space-10); color: rgba(255, 255, 255, 0.85);">{cms.highlights!.subheading}</p>
      <div class="highlights-grid">
        {cms.highlights!.items.map(item => (
          <div class="highlight-item">
            <div class="highlight-number">{item.number}</div>
            <div class="highlight-label">{item.label}</div>
          </div>
        ))}
      </div>
      <div class="text-center" style="margin-top: var(--space-10);">
        <a href={`${base}locations/`} class="btn btn-primary btn-lg">Browse Locations</a>
      </div>
    </div>
  </section>

  <!-- Key Property Features -->
  <WhyUsSection />

  <!-- How the Process Works -->
  <section class="section">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: var(--space-2);">{cms.process!.heading}</h2>
      <p class="text-center text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-10);">{cms.process!.subheading}</p>
      <div class="process-grid">
        {cms.process!.steps.map((step, i) => (
          <div class="process-step">
            <span class="step-number">{i + 1}</span>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Lead Capture Strip -->
  <section class="section lead-strip">
    <div class="container text-center">
      <h2 style="margin-bottom: var(--space-3);">{cms.leadStrip!.heading}</h2>
      <p class="text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-8); max-width: 560px; margin-left: auto; margin-right: auto;">
        {cms.leadStrip!.subheading}
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: var(--space-3); justify-content: center;">
        <a href={`${base}contact/`} class="btn btn-primary btn-lg">Get Availability & Pricing</a>
        <a href="tel:+18285551234" class="btn btn-secondary btn-lg">Call Leasing</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: var(--space-2);">Frequently Asked Questions</h2>
      <p class="text-center text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-8);">Common questions about leasing flex space.</p>
      <FAQAccordion items={homeFaq} />
      <div class="text-center" style="margin-top: var(--space-8);">
        <a href={`${base}faq/`} class="btn btn-secondary">View All FAQ</a>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section final-cta">
    <div class="container text-center">
      <h2 class="text-white" style="margin-bottom: var(--space-4);">{cms.finalCta!.heading}</h2>
      <p style="color: rgba(255,255,255,0.85); font-size: var(--font-size-lg); margin-bottom: var(--space-8); max-width: 500px; margin-left: auto; margin-right: auto;">
        {cms.finalCta!.subheading}
      </p>
      <a href={`${base}contact/`} class="btn btn-primary btn-lg">Get Availability & Pricing</a>
    </div>
  </section>
</BaseLayout>

<style>
  .use-cases {
    background: var(--light-grey);
  }

  .use-case-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .use-case-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .use-case-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .use-case-card {
    background: var(--white);
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    border: 1px solid #E5E7EB;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .use-case-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .uc-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(232, 98, 42, 0.08);
    border-radius: 50%;
    color: var(--orange);
    margin-bottom: var(--space-4);
  }

  .use-case-card h3 {
    font-size: var(--font-size-base);
    font-weight: 700;
    margin-bottom: var(--space-2);
  }

  .use-case-card p {
    font-size: var(--font-size-sm);
    color: var(--slate);
    line-height: 1.6;
  }

  .process-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    max-width: 900px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .process-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .process-step {
    text-align: center;
    padding: var(--space-6);
    background: var(--light-grey);
    border-radius: var(--radius-lg);
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--orange);
    color: var(--white);
    font-weight: 800;
    font-size: var(--font-size-lg);
    border-radius: 50%;
    margin-bottom: var(--space-4);
  }

  .process-step h3 {
    font-size: var(--font-size-base);
    margin-bottom: var(--space-2);
  }

  .process-step p {
    font-size: var(--font-size-sm);
    color: var(--slate);
    line-height: 1.6;
  }

  .lead-strip {
    background: var(--light-grey);
    border-top: 1px solid #E5E7EB;
    border-bottom: 1px solid #E5E7EB;
  }

  .final-cta {
    background: linear-gradient(135deg, var(--navy) 0%, var(--dark) 100%);
  }

  .property-highlights {
    background: linear-gradient(135deg, var(--navy) 0%, var(--dark) 100%);
  }

  .property-highlights h2 {
    color: var(--white);
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    max-width: 800px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .highlights-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .highlight-item {
    text-align: center;
    padding: var(--space-6);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
  }

  .highlight-number {
    font-size: var(--font-size-2xl);
    font-weight: 800;
    color: var(--orange);
    line-height: 1;
    margin-bottom: var(--space-2);
  }

  .highlight-label {
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.85);
    font-weight: 600;
  }
</style>
