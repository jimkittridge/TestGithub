---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import HeroForm from '../components/HeroForm.astro';
import CityCard from '../components/CityCard.astro';
import WhyUsSection from '../components/WhyUsSection.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { cities } from '../data/cities';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const title = 'Small Bay Flex Space for Lease in NC & SC | GetFlexSpace';
const description = 'Flexible 1,000–3,000 SF industrial and flex space suites in Asheville, Durham, and Columbia. Check availability, pricing, and upcoming openings.';

const orgSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'GetFlexSpace',
  url: `https://jimkittridge.github.io/TestGithub/`,
  logo: `https://jimkittridge.github.io/TestGithub/favicon.svg`,
  description,
  contactPoint: { '@type': 'ContactPoint', telephone: '+18285551234', contactType: 'leasing' },
  areaServed: [
    { '@type': 'City', name: 'Asheville', containedInPlace: { '@type': 'State', name: 'North Carolina' } },
    { '@type': 'City', name: 'Durham', containedInPlace: { '@type': 'State', name: 'North Carolina' } },
    { '@type': 'City', name: 'Columbia', containedInPlace: { '@type': 'State', name: 'South Carolina' } },
  ],
});

const cityTaglines: Record<string, string> = {
  'asheville-nc': 'Western NC\'s creative and craft hub. 18–24 ft ceilings, I-26 & I-40 access.',
  'durham-nc': 'Heart of the Research Triangle. 400A 3-phase power, minutes from RTP & RDU.',
  'columbia-sc': 'Crossroads of I-26, I-77 & I-20. Southeast distribution made easy.',
};

const useCases = [
  { title: 'Contractors & Trades', desc: 'HVAC, plumbing, electrical—store your equipment, stage materials, and run your operation from a professional base.', icon: 'hammer' },
  { title: 'E-Commerce & Fulfillment', desc: 'Pack, ship, and store inventory with drive-in access and room to grow your operation.', icon: 'package' },
  { title: 'Light Manufacturing', desc: 'High ceilings and 3-phase power for assembly, fabrication, and production workflows.', icon: 'gear' },
  { title: 'Brewery & Food Production', desc: 'Purpose-built bays with HVAC, plumbing access, and drive-in doors for delivery.', icon: 'beer' },
  { title: 'Creative & Showroom', desc: 'Studios, workshops, and showrooms with the clear height and access your work demands.', icon: 'palette' },
  { title: 'Service Businesses', desc: 'Combined warehouse and office space for service companies that need both.', icon: 'briefcase' },
];

const homeFaq = [
  {
    question: 'What size suites do you offer?',
    answer: 'Our suites range from 1,000 to 3,000 square feet depending on location. We specialize in small bay flex space—the right size for businesses that need more room than an office but less than a full warehouse.',
  },
  {
    question: 'What are the lease terms?',
    answer: 'We offer 1-year, 2-year, and 3-year lease terms. Longer terms may qualify for reduced rates. Contact us to discuss what works best for your business.',
  },
  {
    question: 'What utilities are included?',
    answer: 'Water, sewer, and trash are typically included. Electricity is metered individually per suite. HVAC is included in all suites. Specific inclusions vary by location.',
  },
  {
    question: 'Can I customize my suite?',
    answer: 'Yes. Many tenants add partition walls, mezzanines, specialized lighting, or office space. We work with you on a build-out plan and can offer tenant improvement allowances on longer leases.',
  },
  {
    question: 'How fast can I move in?',
    answer: 'Once approved, you can have keys in as little as two weeks. Start by submitting your requirements and we\'ll guide you through the process.',
  },
  {
    question: 'What if all suites are currently leased?',
    answer: 'Our spaces fill up fast. Submit your information and we\'ll match you with current or upcoming openings—often before they hit the market.',
  },
];
---

<BaseLayout title={title} description={description} schemaMarkup={orgSchema}>
  <!-- Hero -->
  <Hero
    headline="Small Bay Flex Space for Lease in the Carolinas"
    subheadline="1,000–3,000 SF suites designed for contractors, e-commerce, light industrial, and growing businesses."
    layout="split"
  >
    <Fragment slot="copy">
      <ul class="hero-bullets">
        <li>3 markets: Asheville, Durham, Columbia</li>
        <li>Drive-in doors, high ceilings, 24/7 access</li>
        <li>Flexible 1–3 year lease terms</li>
        <li>Response within 1 business day</li>
      </ul>
    </Fragment>
    <HeroForm />
  </Hero>

  <!-- Three-Location Selector -->
  <section class="section">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: var(--space-2);">Find Space by City</h2>
      <p class="text-center text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-10);">Three markets across the Carolinas. Each with suites built for real operators.</p>
      <div class="grid grid-3">
        {cities.map(city => (
          <CityCard
            name={city.name}
            state={city.state}
            slug={city.slug}
            tagline={cityTaglines[city.slug] || ''}
            availability={city.availability}
            specs={`${city.specs.suiteRange} | ${city.specs.ceilingHeight}`}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="section use-cases">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: var(--space-2);">Who It's For</h2>
      <p class="text-center text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-10);">Our tenants run real businesses that need real space.</p>
      <div class="use-case-grid">
        {useCases.map(uc => (
          <div class="use-case-card">
            <div class="uc-icon">
              {uc.icon === 'hammer' && (
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 4v8l-4 4M14 12l4 4"/><rect x="4" y="18" width="6" height="6" rx="1" transform="rotate(-45 4 18)"/></svg>
              )}
              {uc.icon === 'package' && (
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="8" width="20" height="16" rx="2"/><path d="M4 12h20M14 8v16M10 4h8l2 4H8l2-4z"/></svg>
              )}
              {uc.icon === 'gear' && (
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="14" cy="14" r="4"/><path d="M14 2v4M14 22v4M4.93 4.93l2.83 2.83M20.24 20.24l2.83 2.83M2 14h4M22 14h4M4.93 23.07l2.83-2.83M20.24 7.76l2.83-2.83"/></svg>
              )}
              {uc.icon === 'beer' && (
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="6" y="6" width="12" height="18" rx="2"/><path d="M18 10h3a2 2 0 012 2v4a2 2 0 01-2 2h-3"/><path d="M10 12v6M14 12v6"/></svg>
              )}
              {uc.icon === 'palette' && (
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="14" cy="14" r="10"/><circle cx="10" cy="11" r="1.5" fill="currentColor"/><circle cx="17" cy="10" r="1.5" fill="currentColor"/><circle cx="10" cy="17" r="1.5" fill="currentColor"/><path d="M18 16a2 2 0 01-2 2h-1a1 1 0 00-1 1v1"/></svg>
              )}
              {uc.icon === 'briefcase' && (
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="10" width="22" height="14" rx="2"/><path d="M10 10V7a2 2 0 012-2h4a2 2 0 012 2v3"/><path d="M3 16h22"/></svg>
              )}
            </div>
            <h3>{uc.title}</h3>
            <p>{uc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Key Property Features -->
  <WhyUsSection />

  <!-- How the Process Works -->
  <section class="section">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: var(--space-2);">How It Works</h2>
      <p class="text-center text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-10);">Three steps to your new space.</p>
      <div class="process-grid">
        <div class="process-step">
          <span class="step-number">1</span>
          <h3>Submit Requirements</h3>
          <p>Tell us your size, use, and timing. We'll review your needs and identify matching suites.</p>
        </div>
        <div class="process-step">
          <span class="step-number">2</span>
          <h3>Get Matched</h3>
          <p>We'll send you current and upcoming openings that fit your business. No obligation.</p>
        </div>
        <div class="process-step">
          <span class="step-number">3</span>
          <h3>Tour & Apply</h3>
          <p>Walk the space, review the lease, and get your keys. Move-in can happen in as little as two weeks.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Lead Capture Strip -->
  <section class="section lead-strip">
    <div class="container text-center">
      <h2 style="margin-bottom: var(--space-3);">Tell Us What You Need</h2>
      <p class="text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-8); max-width: 560px; margin-left: auto; margin-right: auto;">
        We'll match you with current and upcoming openings across all three markets. No obligation.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: var(--space-3); justify-content: center;">
        <a href={`${base}contact/`} class="btn btn-primary btn-lg">Get Availability & Pricing</a>
        <a href="tel:+18285551234" class="btn btn-secondary btn-lg">Call Leasing</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: var(--space-2);">Frequently Asked Questions</h2>
      <p class="text-center text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-8);">Common questions about leasing flex space.</p>
      <FAQAccordion items={homeFaq} />
      <div class="text-center" style="margin-top: var(--space-8);">
        <a href={`${base}faq/`} class="btn btn-secondary">View All FAQ</a>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section final-cta">
    <div class="container text-center">
      <h2 class="text-white" style="margin-bottom: var(--space-4);">Ready to Find Your Space?</h2>
      <p style="color: rgba(255,255,255,0.85); font-size: var(--font-size-lg); margin-bottom: var(--space-8); max-width: 500px; margin-left: auto; margin-right: auto;">
        Our small bays move fast. Get in touch today to check availability and pricing.
      </p>
      <a href={`${base}contact/`} class="btn btn-primary btn-lg">Get Availability & Pricing</a>
    </div>
  </section>
</BaseLayout>

<style>
  .use-cases {
    background: var(--light-grey);
  }

  .use-case-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .use-case-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .use-case-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .use-case-card {
    background: var(--white);
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .uc-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(232, 98, 42, 0.08);
    border-radius: 50%;
    color: var(--orange);
    margin-bottom: var(--space-4);
  }

  .use-case-card h3 {
    font-size: var(--font-size-base);
    font-weight: 700;
    margin-bottom: var(--space-2);
  }

  .use-case-card p {
    font-size: var(--font-size-sm);
    color: var(--slate);
    line-height: 1.6;
  }

  .process-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    max-width: 900px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .process-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .process-step {
    text-align: center;
    padding: var(--space-6);
    background: var(--light-grey);
    border-radius: var(--radius-lg);
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--orange);
    color: var(--white);
    font-weight: 800;
    font-size: var(--font-size-lg);
    border-radius: 50%;
    margin-bottom: var(--space-4);
  }

  .process-step h3 {
    font-size: var(--font-size-base);
    margin-bottom: var(--space-2);
  }

  .process-step p {
    font-size: var(--font-size-sm);
    color: var(--slate);
    line-height: 1.6;
  }

  .lead-strip {
    background: var(--light-grey);
  }

  .final-cta {
    background: linear-gradient(135deg, var(--navy) 0%, var(--dark) 100%);
  }
</style>
