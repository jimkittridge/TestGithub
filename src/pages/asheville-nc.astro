---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import AvailabilityBadge from '../components/AvailabilityBadge.astro';
import PropertySpecs from '../components/PropertySpecs.astro';
import GoogleMap from '../components/GoogleMap.astro';
import ContactForm from '../components/ContactForm.astro';
import LocalGuide from '../components/LocalGuide.astro';
import { getCityBySlug } from '../data/cities';

const city = getCityBySlug('asheville-nc')!;

const schemaMarkup = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    '@id': `https://getflexspace.com/${city.slug}/`,
    name: `GetFlexSpace ${city.fullName}`,
    description: city.seo.description,
    url: `https://getflexspace.com/${city.slug}/`,
    telephone: city.schema.phone,
    address: {
      '@type': 'PostalAddress',
      streetAddress: city.schema.address.street,
      addressLocality: city.schema.address.city,
      addressRegion: city.schema.address.state,
      postalCode: city.schema.address.zip,
      addressCountry: 'US',
    },
    geo: { '@type': 'GeoCoordinates', latitude: city.schema.geo.lat, longitude: city.schema.geo.lng },
    openingHoursSpecification: {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '00:00',
      closes: '23:59',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'RealEstateListing',
    name: `Flex Space for Lease in ${city.fullName}`,
    description: city.seo.description,
    url: `https://getflexspace.com/${city.slug}/`,
  },
]);
---

<BaseLayout title={city.seo.title} description={city.seo.description} schemaMarkup={schemaMarkup}>
  <Hero
    headline={`Flex Space for Lease in ${city.fullName}.`}
    subheadline={`${city.specs.suiteRange} suites with ${city.specs.doorSize.toLowerCase()} doors, ${city.specs.ceilingHeight.toLowerCase()} ceilings, and 24/7 access.`}
    ctaButtons={[
      { label: 'Check Availability', href: '#contact-form', variant: 'primary' },
      { label: 'View Specs', href: '#specs', variant: 'white' },
    ]}
  />

  <AvailabilityBadge availability={city.availability} availableUnits={city.availableUnits} />

  <div id="specs">
    <PropertySpecs specs={city.specs} />
  </div>

  <GoogleMap embedUrl={city.mapEmbedUrl} title={`GetFlexSpace ${city.fullName}`} />

  <ContactForm citySlug={city.slug} cityName={city.name} />

  <LocalGuide
    heading={city.localGuide.heading}
    paragraphs={city.localGuide.paragraphs}
    nearbyHighways={city.localGuide.nearbyHighways}
  />
</BaseLayout>
