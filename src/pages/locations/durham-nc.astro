---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import AvailabilityBadge from '../../components/AvailabilityBadge.astro';
import PropertySpecs from '../../components/PropertySpecs.astro';
import GoogleMap from '../../components/GoogleMap.astro';
import ContactForm from '../../components/ContactForm.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { getCityBySlug, cities } from '../../data/cities';

const city = getCityBySlug('durham-nc')!;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const otherCities = cities.filter(c => c.slug !== city.slug);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `https://jimkittridge.github.io/TestGithub/` },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `https://jimkittridge.github.io/TestGithub/locations/` },
    { '@type': 'ListItem', position: 3, name: city.fullName },
  ],
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `https://jimkittridge.github.io/TestGithub/locations/${city.slug}/`,
  name: `GetFlexSpace ${city.fullName}`,
  description: city.seo.description,
  url: `https://jimkittridge.github.io/TestGithub/locations/${city.slug}/`,
  telephone: city.schema.phone,
  address: {
    '@type': 'PostalAddress',
    streetAddress: city.schema.address.street,
    addressLocality: city.schema.address.city,
    addressRegion: city.schema.address.state,
    postalCode: city.schema.address.zip,
    addressCountry: 'US',
  },
  geo: { '@type': 'GeoCoordinates', latitude: city.schema.geo.lat, longitude: city.schema.geo.lng },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    opens: '00:00',
    closes: '23:59',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: city.faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};

const schemaMarkup = JSON.stringify([breadcrumbSchema, localBusinessSchema, faqSchema]);
---

<BaseLayout title={city.seo.title} description={city.seo.description} schemaMarkup={schemaMarkup}>
  <!-- Hero -->
  <Hero
    headline={`Small Bay Flex Space for Lease in ${city.fullName}`}
    subheadline={`${city.specs.suiteRange} suites with drive-in doors, ${city.specs.ceilingHeight.toLowerCase()} ceilings, HVAC, and 24/7 access for contractors, warehouse, and light industrial users.`}
    ctaButtons={[
      { label: 'Get Availability & Pricing', href: '#contact-form', variant: 'primary' },
      { label: 'View Suite Features', href: '#specs', variant: 'white' },
    ]}
  >
    <div class="hero-trust">
      <p class="hero-scarcity">Suites lease quickly in {city.name}. Tell us your size, use, and timing, and we'll send current matches and upcoming openings.</p>
      <ul class="hero-bullets">
        <li>Typical suites: {city.specs.suiteRange}</li>
        <li>Best for contractors, e-commerce, and light industrial</li>
        <li>Direct to leasing</li>
        <li>Fast response</li>
      </ul>
    </div>
  </Hero>

  <AvailabilityBadge availability={city.availability} availableUnits={city.availableUnits} cityName={city.name} />

  <!-- Best For Section -->
  <section class="section best-for">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: var(--space-2);">A Good Fit for {city.name} Businesses That Need Practical Flex Space</h2>
      <p class="text-center text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-8);">These suites work well for operators who need functional small bay space with warehouse capability, flexible access, and room to grow.</p>
      <div class="tenant-grid">
        {city.tenantProfiles.map(profile => (
          <div class="tenant-card">
            <h3 class="tenant-title">{profile.title}</h3>
            <p class="tenant-desc">{profile.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Suite Features -->
  <div id="specs">
    <section class="section">
      <div class="container">
        <h2 class="text-center" style="margin-bottom: var(--space-2);">Suite Features</h2>
        <p class="text-center text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-8);">Built for businesses that need efficient, usable industrial space without the footprint of a larger warehouse.</p>
        <PropertySpecs specs={city.specs} />
        <div class="text-center" style="margin-top: var(--space-8);">
          <a href="#contact-form" class="btn btn-primary btn-lg">Get Availability & Pricing</a>
        </div>
      </div>
    </section>
  </div>

  <!-- Why This Location -->
  <section class="section why-location">
    <div class="container">
      <div class="why-content">
        <h2>{city.localGuide.heading}</h2>
        {city.localGuide.paragraphs.map(p => (
          <p>{p}</p>
        ))}

        <div class="location-details">
          <div class="detail-block">
            <h4>Major Highway Access</h4>
            <div class="tag-list">
              {city.localGuide.nearbyHighways.map(hw => (
                <span class="tag">{hw}</span>
              ))}
            </div>
          </div>

          <div class="detail-block">
            <h4>Nearest Airport</h4>
            <p>{city.localGuide.airport}</p>
          </div>

          <div class="detail-block">
            <h4>Submarkets Served</h4>
            <div class="tag-list">
              {city.localGuide.submarkets.map(sm => (
                <span class="tag">{sm}</span>
              ))}
            </div>
          </div>

          <div class="detail-block">
            <h4>Local Demand Drivers</h4>
            <ul class="demand-list">
              {city.localGuide.demandDrivers.map(dd => (
                <li>{dd}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="section">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: var(--space-2);">{city.name} Location</h2>
      <p class="text-center text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-8);">Conveniently positioned for businesses serving {city.name} and surrounding markets.</p>
      <GoogleMap embedUrl={city.mapEmbedUrl} title={`GetFlexSpace ${city.fullName}`} />
    </div>
  </section>

  <!-- How It Works -->
  <section class="section process-section">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: var(--space-2);">How It Works</h2>
      <p class="text-center text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-10);">Three steps to your new space.</p>
      <div class="process-grid">
        <div class="process-step">
          <span class="step-number">1</span>
          <h3>Tell Us What You Need</h3>
          <p>Share your business type, size range, and move-in timing.</p>
        </div>
        <div class="process-step">
          <span class="step-number">2</span>
          <h3>We Match You to Suites</h3>
          <p>We review your requirements and send current matches and likely upcoming openings.</p>
        </div>
        <div class="process-step">
          <span class="step-number">3</span>
          <h3>Tour or Apply</h3>
          <p>If there's a fit, we'll move to the next step quickly.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mid-page CTA -->
  <section class="section mid-cta">
    <div class="container text-center">
      <h2 style="margin-bottom: var(--space-3);">Need Flex Space in {city.name} in the Next 30–120 Days?</h2>
      <p class="text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-8); max-width: 560px; margin-left: auto; margin-right: auto;">
        Tell us your size, use, and timing. We'll send matching current and upcoming suites.
      </p>
      <a href="#contact-form" class="btn btn-primary btn-lg">Get Availability & Pricing</a>
    </div>
  </section>

  <!-- Form -->
  <ContactForm citySlug={city.slug} cityName={city.name} />

  <!-- FAQ -->
  <section class="section" id="faq">
    <div class="container">
      <h2 class="text-center" style="margin-bottom: var(--space-2);">{city.name} Flex Space FAQ</h2>
      <p class="text-center text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-8);">Common questions about flex space in {city.name}.</p>
      <FAQAccordion items={city.faq} />
    </div>
  </section>

  <!-- Other Locations -->
  <section class="section cross-links">
    <div class="container text-center">
      <h2 style="margin-bottom: var(--space-2);">Other Locations</h2>
      <p class="text-slate" style="font-size: var(--font-size-lg); margin-bottom: var(--space-8);">We also have flex space in these markets.</p>
      <div class="cross-link-cards">
        {otherCities.map(c => (
          <a href={`${base}locations/${c.slug}/`} class="cross-link-card">
            <h3>Flex Space in {c.fullName}</h3>
            <p>{c.specs.suiteRange} suites</p>
            <span class="card-arrow">View Details &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section final-cta">
    <div class="container text-center">
      <h2 class="text-white" style="margin-bottom: var(--space-4);">Looking for Small Bay Flex Space in {city.fullName}?</h2>
      <p style="color: rgba(255,255,255,0.85); font-size: var(--font-size-lg); margin-bottom: var(--space-8); max-width: 560px; margin-left: auto; margin-right: auto;">
        If your business needs {city.specs.suiteRange} with warehouse functionality, tell us what you need and we'll send matching current and upcoming suites.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: var(--space-3); justify-content: center;">
        <a href="#contact-form" class="btn btn-primary btn-lg">Get Availability & Pricing</a>
        <a href="tel:+18285551234" class="btn btn-white btn-lg">Call Leasing</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-trust {
    margin-top: var(--space-8);
  }

  .hero-scarcity {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--font-size-base);
    max-width: 560px;
    margin: 0 auto var(--space-6);
    line-height: 1.6;
  }

  .hero-bullets {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2) var(--space-6);
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--font-size-sm);
    font-weight: 600;
  }

  .hero-bullets li {
    position: relative;
    padding-left: var(--space-4);
  }

  .hero-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 6px;
    height: 6px;
    background: var(--orange);
    border-radius: 50%;
  }

  .best-for {
    background: var(--light-grey);
  }

  .tenant-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    max-width: 900px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .tenant-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .tenant-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .tenant-card {
    padding: var(--space-6);
    background: var(--white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .tenant-title {
    font-size: var(--font-size-base);
    font-weight: 700;
    margin-bottom: var(--space-2);
    color: var(--navy);
  }

  .tenant-desc {
    font-size: var(--font-size-sm);
    color: var(--slate);
    line-height: 1.6;
  }

  .why-content {
    max-width: 720px;
    margin: 0 auto;
  }

  .why-content h2 {
    margin-bottom: var(--space-6);
  }

  .why-content > p {
    color: var(--slate);
    font-size: var(--font-size-base);
    line-height: 1.8;
    margin-bottom: var(--space-4);
  }

  .location-details {
    margin-top: var(--space-8);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .location-details {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .detail-block h4 {
    font-size: var(--font-size-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--navy);
    margin-bottom: var(--space-3);
  }

  .detail-block p {
    color: var(--slate);
    font-size: var(--font-size-base);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    display: inline-block;
    background: var(--light-grey);
    color: var(--navy);
    font-size: var(--font-size-xs);
    font-weight: 700;
    padding: var(--space-1) var(--space-3);
    border-radius: 100px;
  }

  .demand-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .demand-list li {
    color: var(--slate);
    font-size: var(--font-size-sm);
    padding-left: var(--space-4);
    position: relative;
  }

  .demand-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    background: var(--orange);
    border-radius: 50%;
  }

  .process-section {
    background: var(--light-grey);
  }

  .process-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    max-width: 900px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .process-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .process-step {
    text-align: center;
    padding: var(--space-6);
    background: var(--white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--orange);
    color: var(--white);
    font-weight: 800;
    font-size: var(--font-size-lg);
    border-radius: 50%;
    margin-bottom: var(--space-4);
  }

  .process-step h3 {
    font-size: var(--font-size-base);
    margin-bottom: var(--space-2);
  }

  .process-step p {
    font-size: var(--font-size-sm);
    color: var(--slate);
    line-height: 1.6;
  }

  .mid-cta {
    background: var(--light-grey);
  }

  .cross-links {
    background: var(--light-grey);
  }

  .cross-link-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    max-width: 600px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .cross-link-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .cross-link-card {
    display: block;
    padding: var(--space-6);
    background: var(--white);
    border: 2px solid var(--light-grey);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .cross-link-card:hover {
    border-color: var(--orange);
    box-shadow: var(--shadow-md);
  }

  .cross-link-card h3 {
    font-size: var(--font-size-base);
    color: var(--navy);
    margin-bottom: var(--space-1);
  }

  .cross-link-card p {
    font-size: var(--font-size-sm);
    color: var(--slate);
    margin-bottom: var(--space-3);
  }

  .card-arrow {
    font-size: var(--font-size-sm);
    font-weight: 700;
    color: var(--orange);
  }

  .final-cta {
    background: linear-gradient(135deg, var(--navy) 0%, var(--dark) 100%);
  }
</style>
