---
import NewLayout from '../../layouts/NewLayout.astro';
import LeadForm from '../../components/LeadForm.astro';
import { getCollection } from 'astro:content';

const allLocations = await getCollection('locations');
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const title = 'Flex Space Locations in NC & SC | GetFlexSpace';
const description = 'Find small bay flex space for lease in Asheville NC, Durham NC, and Columbia SC. 1,000–3,000 SF suites with drive-in doors, high ceilings, and 24/7 access.';

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://getflexspace.com/' },
    { '@type': 'ListItem', position: 2, name: 'Locations' },
  ],
});

const locationImages: Record<string, string> = {
  'durham-nc': 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&w=1200&q=80',
  'asheville-nc': 'https://images.unsplash.com/photo-1513828583688-c52646db42da?auto=format&fit=crop&w=1200&q=80',
  'columbia-sc': 'https://images.unsplash.com/photo-1494412519320-aa613dfb7738?auto=format&fit=crop&w=1200&q=80',
};
---

<NewLayout title={title} description={description} schemaMarkup={breadcrumbSchema}>

  <!-- Breadcrumb -->
  <div class="bg-[#f7f5f1] border-b border-black/5">
    <div class="mx-auto max-w-7xl px-6 py-3 lg:px-8">
      <nav class="flex items-center gap-2 text-sm text-black/45">
        <a href={base} class="no-underline text-black/45 hover:text-black transition">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-black/70 font-medium">Locations</span>
      </nav>
    </div>
  </div>

  <!-- Header -->
  <section class="py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="text-sm uppercase tracking-[0.16em] text-black/45">Locations</div>
        <h1 class="mt-3 text-5xl font-semibold tracking-[-0.03em] text-[#111] sm:text-6xl" style="color: #111;">
          Small bay flex space across the Carolinas.
        </h1>
        <p class="mt-6 text-xl leading-8 text-black/64">
          Browse current markets, check availability status, and find the right flex industrial space for your business.
        </p>
      </div>
    </div>
  </section>

  <!-- Location Cards -->
  <section class="pb-20 lg:pb-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid gap-6 lg:grid-cols-3">
        {allLocations.map(loc => {
          const isAvailable = loc.data.availability === 'available';
          const image = locationImages[loc.data.slug] || locationImages['durham-nc'];
          return (
            <a href={`${base}locations/${loc.data.slug}/`} class="block overflow-hidden rounded-[30px] border border-black/10 bg-white shadow-[0_15px_40px_rgba(0,0,0,0.05)] no-underline transition hover:shadow-[0_20px_50px_rgba(0,0,0,0.1)]">
              <div class="aspect-[4/3] overflow-hidden">
                <img src={image} alt={`Flex warehouse space in ${loc.data.fullName}`} class="h-full w-full object-cover transition duration-500 hover:scale-[1.03]" loading="lazy" />
              </div>
              <div class="p-6">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <div class="text-2xl font-semibold tracking-[-0.02em] text-[#111]">{loc.data.fullName}</div>
                    <div class="mt-1 text-sm text-black/50">{loc.data.specs.suiteRange}</div>
                  </div>
                  <span class:list={[
                    'rounded-full px-3 py-1 text-xs font-medium shrink-0',
                    isAvailable
                      ? 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-200'
                      : 'bg-zinc-100 text-zinc-700 ring-1 ring-zinc-200'
                  ]}>
                    {isAvailable ? 'Available now' : 'Waitlist'}
                  </span>
                </div>
                <p class="mt-4 text-sm leading-6 text-black/60">{loc.data.tagline}</p>
                <div class="mt-4 grid grid-cols-2 gap-2">
                  <div class="rounded-xl border border-black/8 bg-[#fbfaf8] px-3 py-2">
                    <div class="text-[10px] uppercase tracking-[0.12em] text-black/40">Ceiling</div>
                    <div class="text-xs font-medium text-[#111]">{loc.data.specs.ceilingHeight}</div>
                  </div>
                  <div class="rounded-xl border border-black/8 bg-[#fbfaf8] px-3 py-2">
                    <div class="text-[10px] uppercase tracking-[0.12em] text-black/40">Power</div>
                    <div class="text-xs font-medium text-[#111]">{loc.data.specs.power}</div>
                  </div>
                </div>
                <div class="mt-5 flex items-center justify-between rounded-2xl border border-black/10 bg-[#fbfaf8] px-4 py-3 text-sm text-black/70">
                  <span>View {loc.data.name} details</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pb-20 lg:pb-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="rounded-[36px] border border-black/10 bg-black p-8 text-white lg:p-10">
        <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
          <div>
            <div class="text-sm uppercase tracking-[0.16em] text-white/45">Not sure which location?</div>
            <h2 class="mt-3 text-4xl font-semibold tracking-[-0.03em] text-white" style="color: white; font-size: clamp(1.75rem, 1.3rem + 2.25vw, 2.5rem);">
              Tell us what you need.
            </h2>
            <p class="mt-4 max-w-2xl text-lg leading-8 text-white/72">
              We'll match you with the best suite across all three markets and respond within 1 business day.
            </p>
          </div>
          <div class="w-full max-w-sm rounded-[28px] bg-white p-5 text-black">
            <LeadForm compact buttonLabel="Get matched" />
          </div>
        </div>
      </div>
    </div>
  </section>

</NewLayout>
