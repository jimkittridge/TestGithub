---
import NewLayout from '../../layouts/NewLayout.astro';
import LeadForm from '../../components/LeadForm.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allLocations = await getCollection('locations');
  return allLocations.map(location => ({
    params: { slug: location.data.slug },
    props: { location },
  }));
}

const { location } = Astro.props;
const city = location.data;
const { Content } = await render(location);
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const allLocations = await getCollection('locations');
const otherCities = allLocations.filter(c => c.data.slug !== city.slug);

const isAvailable = city.availability === 'available';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://getflexspace.com/' },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: 'https://getflexspace.com/locations/' },
    { '@type': 'ListItem', position: 3, name: city.fullName },
  ],
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `https://getflexspace.com/locations/${city.slug}/`,
  name: `GetFlexSpace ${city.fullName}`,
  description: city.seo.description,
  url: `https://getflexspace.com/locations/${city.slug}/`,
  telephone: city.schema.phone,
  address: {
    '@type': 'PostalAddress',
    streetAddress: city.schema.address.street,
    addressLocality: city.schema.address.city,
    addressRegion: city.schema.address.state,
    postalCode: city.schema.address.zip,
    addressCountry: 'US',
  },
  geo: { '@type': 'GeoCoordinates', latitude: city.schema.geo.lat, longitude: city.schema.geo.lng },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    opens: '00:00',
    closes: '23:59',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: city.faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};

const schemaMarkup = JSON.stringify([breadcrumbSchema, localBusinessSchema, faqSchema]);

/* Use CMS image for both hero and featured image */
const heroImage = city.image || '';
const warehouseImage = city.image || '';

/* Sort suites: available first, then by size (smallest to largest) */
const parseSF = (s: string) => parseInt(s.replace(/[^0-9]/g, '')) || 0;
const suites = [...(city.suites || [])].sort((a, b) => {
  if (a.status === 'available' && b.status !== 'available') return -1;
  if (a.status !== 'available' && b.status === 'available') return 1;
  return parseSF(a.size) - parseSF(b.size);
});

const specItems = [
  ['Ceiling', city.specs.ceilingHeight],
  ['Power', city.specs.power],
  ['Door', city.specs.doorSize],
  ['HVAC', city.specs.hvac],
  ['Suites', city.specs.suiteRange],
];
---

<NewLayout title={city.seo.title} description={city.seo.description} schemaMarkup={schemaMarkup}>

  <!-- ===== BREADCRUMB ===== -->
  <div class="bg-[#f7f5f1] border-b border-black/5">
    <div class="mx-auto max-w-7xl px-6 py-3 lg:px-8">
      <nav class="flex items-center gap-2 text-sm text-black/45">
        <a href={base} class="no-underline text-black/45 hover:text-black transition">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <a href={`${base}locations/`} class="no-underline text-black/45 hover:text-black transition">Locations</a>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-black/70 font-medium">{city.fullName}</span>
      </nav>
    </div>
  </div>

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden bg-black text-white">
    <div class="absolute inset-0">
      <img src={heroImage} alt={`Flex warehouse space in ${city.fullName}`} class="h-full w-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-6 pb-24 pt-14 lg:px-8 lg:pb-32 lg:pt-20">
      <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
        <div>
          <div class="flex flex-wrap items-center gap-3 mb-6">
            <span class:list={[
              'rounded-full px-3 py-1 text-xs font-medium',
              isAvailable
                ? 'bg-emerald-500/20 text-emerald-300 ring-1 ring-emerald-400/30'
                : 'bg-white/10 text-white/70 ring-1 ring-white/20'
            ]}>
              {isAvailable ? 'Available now' : 'Waitlist open'}
            </span>
            {city.availableUnits && (
              <span class="text-sm text-white/60">{city.availableUnits}</span>
            )}
          </div>
          <h1 class="text-4xl font-semibold leading-[1.05] tracking-[-0.03em] text-white sm:text-5xl lg:text-6xl" style="color: white;">
            Flex warehouse space in {city.fullName}
          </h1>
          <p class="mt-6 max-w-xl text-lg leading-8 text-white/75">
            {city.tagline}
          </p>
          <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
            {specItems.map(([label, value]) => (
              <div class="rounded-2xl border border-white/10 bg-white/5 px-3 py-3">
                <div class="text-[11px] uppercase tracking-[0.14em] text-white/40">{label}</div>
                <div class="mt-1 text-sm font-medium text-white/90">{value}</div>
              </div>
            ))}
          </div>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href="#lead-form" class="inline-flex items-center gap-2 rounded-2xl bg-white px-6 py-3 text-sm font-medium text-black no-underline hover:bg-white/90 transition">
              Get availability &amp; pricing
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a href={`tel:${city.schema.phone}`} class="inline-flex items-center rounded-2xl border border-white/20 bg-white/10 px-6 py-3 text-sm font-medium text-white no-underline hover:bg-white/15 transition">
              Call leasing
            </a>
          </div>
        </div>
        <!-- Hero Lead Form -->
        <div class="rounded-[28px] bg-white p-6 text-black shadow-[0_24px_80px_rgba(0,0,0,0.25)]">
          <div class="text-sm uppercase tracking-[0.14em] text-black/45 mb-2">Get availability</div>
          <div class="text-xl font-semibold tracking-[-0.02em] text-[#111] mb-1">
            Interested in {city.name}?
          </div>
          <p class="text-sm text-black/55 mb-5">Tell us who you are and we'll respond within 1 business day.</p>
          <LeadForm compact buttonLabel={`Get ${city.name} availability`} />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FEATURED IMAGE ===== -->
  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="overflow-hidden rounded-[34px] border border-black/10 bg-white shadow-[0_20px_60px_rgba(0,0,0,0.08)]">
        <div class="aspect-[16/7] overflow-hidden lg:aspect-[16/6]">
          <img src={warehouseImage} alt={`Interior of flex warehouse space in ${city.fullName}`} class="h-full w-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SUITES / AVAILABILITY ===== -->
  {suites.length > 0 && (
    <section class="py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mb-10 max-w-3xl">
          <div class="text-sm uppercase tracking-[0.16em] text-black/45">Availability</div>
          <h2 class="mt-3 text-4xl font-semibold tracking-[-0.03em]" style="color: #111; font-size: clamp(1.75rem, 1.3rem + 2.25vw, 2.5rem);">
            {city.name} warehouse suites and unit sizes
          </h2>
          <p class="mt-4 text-lg leading-8 text-black/64">
            {suites.length === 1
              ? `One suite type currently offered at this location.`
              : `${suites.length} suite types available at this location. Available units are shown first.`}
          </p>
        </div>
        <div class="grid gap-6 lg:grid-cols-2">
          {suites.map((suite) => {
            const isAvail = suite.status === 'available';
            return (
              <div class="rounded-[28px] border border-black/10 bg-white p-6 shadow-[0_10px_24px_rgba(0,0,0,0.03)] lg:p-8">
                <div class="flex items-center justify-between gap-4">
                  <div class="text-xs uppercase tracking-[0.14em] text-black/42">
                    {isAvail ? 'Available suite' : 'Additional suite type'}
                  </div>
                  <span class:list={[
                    'rounded-full px-3 py-1 text-xs font-medium shrink-0',
                    isAvail
                      ? 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-200'
                      : 'bg-zinc-100 text-zinc-700 ring-1 ring-zinc-200'
                  ]}>
                    {isAvail ? 'Available now' : 'Waitlist'}
                  </span>
                </div>
                <div class="mt-3 text-3xl font-semibold tracking-[-0.03em] text-[#111]">
                  {suite.size}
                </div>
                <p class="mt-3 text-black/62 leading-7">
                  {suite.description}
                </p>
                <div class="mt-6 grid grid-cols-2 gap-3">
                  {[
                    ['Clear height', suite.ceilingHeight],
                    ['Power', suite.power],
                    ['Door', suite.door],
                    ['Lease', suite.lease],
                  ].map(([label, value]) => (
                    <div class="rounded-2xl border border-black/10 bg-[#fbfaf8] px-4 py-4">
                      <div class="text-xs uppercase tracking-[0.14em] text-black/42">{label}</div>
                      <div class="mt-1 text-sm font-medium text-[#111]">{value}</div>
                    </div>
                  ))}
                </div>
                <div class="mt-6 flex flex-wrap items-center gap-5 text-sm font-medium text-black/78">
                  <a href="#lead-form" class="inline-flex items-center gap-2 hover:text-black no-underline text-black/78">
                    {isAvail ? 'Request pricing' : 'Join waitlist'}
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </a>
                  <a href={`${base}contact/`} class="hover:text-black no-underline text-black/78">Schedule a tour</a>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ===== BEST FOR / TENANT PROFILES ===== -->
  <section class="bg-white/65 py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-10 max-w-3xl">
        <div class="text-sm uppercase tracking-[0.16em] text-black/45">Who it's for</div>
        <h2 class="mt-3 text-4xl font-semibold tracking-[-0.03em]" style="color: #111; font-size: clamp(1.75rem, 1.3rem + 2.25vw, 2.5rem);">
          A good fit for {city.name} businesses that need practical flex space.
        </h2>
        <p class="mt-4 text-lg leading-8 text-black/64">
          These suites work well for operators who need functional small bay space with warehouse capability, flexible access, and room to grow.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {city.tenantProfiles.map((profile: { title: string; description: string }) => (
          <div class="rounded-[24px] border border-black/10 bg-white p-6 shadow-[0_10px_24px_rgba(0,0,0,0.03)]">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-black/10 bg-[#fbfaf8] mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
            </div>
            <div class="text-lg font-semibold tracking-[-0.01em] text-[#111]">{profile.title}</div>
            <p class="mt-2 leading-7 text-black/62">{profile.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SUITE SPECS ===== -->
  <section id="specs" class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="rounded-[36px] border border-black/10 bg-white p-8 shadow-[0_18px_50px_rgba(0,0,0,0.05)] lg:p-10">
        <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <div>
            <div class="text-sm uppercase tracking-[0.16em] text-black/45">Suite specs</div>
            <h2 class="mt-3 text-4xl font-semibold tracking-[-0.03em]" style="color: #111; font-size: clamp(1.75rem, 1.3rem + 2.25vw, 2.5rem);">
              Built for businesses that need efficient, usable industrial space.
            </h2>
            <p class="mt-5 text-lg leading-8 text-black/64">
              Hard specs up front so you can evaluate fit before filling out a form.
            </p>
            <a href="#lead-form" class="mt-6 inline-flex items-center gap-2 rounded-2xl bg-black px-6 py-3 text-sm font-medium text-white no-underline hover:bg-black/85 transition">
              Get availability &amp; pricing
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            {specItems.map(([label, value]) => (
              <div class="rounded-[20px] border border-black/10 bg-[#fbfaf8] p-5">
                <div class="text-xs uppercase tracking-[0.14em] text-black/42">{label}</div>
                <div class="mt-2 text-xl font-semibold tracking-[-0.01em] text-[#111]">{value}</div>
              </div>
            ))}
            <div class="rounded-[20px] border border-black/10 bg-[#fbfaf8] p-5">
              <div class="text-xs uppercase tracking-[0.14em] text-black/42">Access</div>
              <div class="mt-2 text-xl font-semibold tracking-[-0.01em] text-[#111]">24/7/365</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY THIS LOCATION ===== -->
  <section class="bg-[#ece7df] py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[1fr_1fr] lg:items-start">
        <div>
          <div class="text-sm uppercase tracking-[0.16em] text-black/45">Local market</div>
          <h2 class="mt-3 text-4xl font-semibold tracking-[-0.03em]" style="color: #111; font-size: clamp(1.75rem, 1.3rem + 2.25vw, 2.5rem);">
            {city.localGuide.heading}
          </h2>
          <div class="mt-6 prose-location">
            <Content />
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <!-- Highways -->
          <div class="rounded-[24px] border border-black/10 bg-white p-5">
            <div class="text-xs font-semibold uppercase tracking-[0.14em] text-black/45 mb-3">Major highway access</div>
            <div class="flex flex-wrap gap-2">
              {city.localGuide.nearbyHighways.map((hw: string) => (
                <span class="rounded-full border border-black/10 bg-[#fbfaf8] px-3 py-1 text-sm font-medium text-[#111]">{hw}</span>
              ))}
            </div>
          </div>
          <!-- Airport -->
          <div class="rounded-[24px] border border-black/10 bg-white p-5">
            <div class="text-xs font-semibold uppercase tracking-[0.14em] text-black/45 mb-3">Nearest airport</div>
            <div class="text-sm font-medium text-[#111]">{city.localGuide.airport}</div>
          </div>
          <!-- Submarkets -->
          <div class="rounded-[24px] border border-black/10 bg-white p-5">
            <div class="text-xs font-semibold uppercase tracking-[0.14em] text-black/45 mb-3">Submarkets served</div>
            <div class="flex flex-wrap gap-2">
              {city.localGuide.submarkets.map((sm: string) => (
                <span class="rounded-full border border-black/10 bg-[#fbfaf8] px-3 py-1 text-sm text-black/70">{sm}</span>
              ))}
            </div>
          </div>
          <!-- Demand Drivers -->
          <div class="rounded-[24px] border border-black/10 bg-white p-5">
            <div class="text-xs font-semibold uppercase tracking-[0.14em] text-black/45 mb-3">Local demand drivers</div>
            <ul class="space-y-2 list-none p-0 m-0">
              {city.localGuide.demandDrivers.map((dd: string) => (
                <li class="flex items-start gap-2 text-sm text-black/70">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-black/40"><path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
                  {dd}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MAP ===== -->
  <section class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 max-w-2xl">
        <div class="text-sm uppercase tracking-[0.16em] text-black/45">Location</div>
        <h2 class="mt-3 text-4xl font-semibold tracking-[-0.03em]" style="color: #111; font-size: clamp(1.75rem, 1.3rem + 2.25vw, 2.5rem);">
          {city.name} area
        </h2>
        <p class="mt-4 text-lg leading-8 text-black/64">
          Conveniently positioned for businesses serving {city.name} and surrounding markets.
        </p>
      </div>
      <div class="overflow-hidden rounded-[28px] border border-black/10 shadow-[0_10px_30px_rgba(0,0,0,0.06)]">
        <iframe
          src={city.mapEmbedUrl}
          width="100%"
          height="450"
          style="border:0; display:block;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Map of GetFlexSpace ${city.fullName}`}
        ></iframe>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="bg-white/65 py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-10 max-w-2xl">
        <div class="text-sm uppercase tracking-[0.16em] text-black/45">How it works</div>
        <h2 class="mt-3 text-4xl font-semibold tracking-[-0.03em]" style="color: #111; font-size: clamp(1.75rem, 1.3rem + 2.25vw, 2.5rem);">
          From inquiry to move-in.
        </h2>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {[
          { n: '01', t: 'Tell us what you need', d: 'Share your business type, size range, and move-in timing.' },
          { n: '02', t: 'We match you to suites', d: 'We review your requirements and send current matches and upcoming openings.' },
          { n: '03', t: 'Tour or apply', d: 'If there\'s a fit, we\'ll move to the next step quickly.' },
        ].map(step => (
          <div class="rounded-[24px] border border-black/10 bg-white p-6 shadow-[0_10px_24px_rgba(0,0,0,0.03)]">
            <div class="text-sm font-medium text-black/40">{step.n}</div>
            <div class="mt-3 text-xl font-semibold tracking-[-0.01em] text-[#111]">{step.t}</div>
            <p class="mt-2 leading-7 text-black/62">{step.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== LEAD FORM (main) ===== -->
  <section id="lead-form" class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="rounded-[36px] border border-black/10 bg-[#f3eee7] p-8 shadow-[0_18px_50px_rgba(0,0,0,0.06)] lg:p-10">
        <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
          <div>
            <div class="text-sm uppercase tracking-[0.16em] text-black/45">Get availability and pricing</div>
            <h2 class="mt-3 text-3xl font-semibold tracking-[-0.03em] text-[#111]">
              Interested in flex space in {city.name}?
            </h2>
            <p class="mt-4 text-black/62">
              Tell us who you are and how to reach you. We respond within 1 business day with availability, pricing, and next steps.
            </p>
          </div>
          <div>
            <LeadForm layout="inline" buttonLabel={`Get ${city.name} availability`} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section id="faq" class="bg-white/65 py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-10 max-w-3xl">
        <div class="text-sm uppercase tracking-[0.16em] text-black/45">FAQ</div>
        <h2 class="mt-3 text-4xl font-semibold tracking-[-0.03em]" style="color: #111; font-size: clamp(1.75rem, 1.3rem + 2.25vw, 2.5rem);">
          {city.name} flex space FAQ
        </h2>
      </div>
      <div class="grid gap-5 lg:grid-cols-2">
        {city.faq.map((item: { question: string; answer: string }) => (
          <div class="rounded-[28px] border border-black/10 bg-white p-6 shadow-[0_10px_24px_rgba(0,0,0,0.03)]">
            <div class="text-lg font-semibold tracking-[-0.01em] text-[#111]">{item.question}</div>
            <div class="mt-3 leading-7 text-black/62">{item.answer}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== OTHER LOCATIONS ===== -->
  <section class="py-20 lg:py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8">
        <div class="text-sm uppercase tracking-[0.16em] text-black/45">Other markets</div>
        <h2 class="mt-3 text-3xl font-semibold tracking-[-0.03em] text-[#111]">
          Also available in {otherCities.map(c => c.data.fullName).join(' and ')}.
        </h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {otherCities.map(c => (
          <a href={`${base}locations/${c.data.slug}/`} class="flex items-center justify-between rounded-[24px] border border-black/10 bg-white p-6 shadow-[0_10px_24px_rgba(0,0,0,0.03)] no-underline transition hover:shadow-[0_15px_40px_rgba(0,0,0,0.08)]">
            <div>
              <div class="text-xl font-semibold tracking-[-0.02em] text-[#111]">Flex space in {c.data.fullName}</div>
              <div class="mt-1 text-sm text-black/55">{c.data.specs.suiteRange} suites</div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-black/40"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="pb-20 lg:pb-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="rounded-[36px] border border-black/10 bg-black p-8 text-white lg:p-10">
        <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
          <div>
            <div class="text-sm uppercase tracking-[0.16em] text-white/45">Get started</div>
            <h2 class="mt-3 text-4xl font-semibold tracking-[-0.03em] text-white" style="color: white; font-size: clamp(1.75rem, 1.3rem + 2.25vw, 2.5rem);">
              Looking for flex industrial space in {city.fullName}?
            </h2>
            <p class="mt-4 max-w-2xl text-lg leading-8 text-white/72">
              {city.specs.suiteRange} suites with {city.specs.ceilingHeight.toLowerCase()} ceilings, {city.specs.doorSize.toLowerCase()} doors, and 24/7 access. Submit your details for pricing and next steps.
            </p>
          </div>
          <div class="w-full max-w-sm rounded-[28px] bg-white p-5 text-black">
            <LeadForm compact buttonLabel="Get availability" />
          </div>
        </div>
      </div>
    </div>
  </section>

</NewLayout>

