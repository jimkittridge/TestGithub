---
import NewLayout from '../layouts/NewLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'contact');
const cms = page!.data;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<NewLayout title={cms.seo.title} description={cms.seo.description}>

  <!-- Breadcrumb -->
  <div class="border-b border-black/5 bg-[#f7f5f1]">
    <div class="mx-auto max-w-7xl px-6 py-3 lg:px-8">
      <nav class="flex items-center gap-2 text-sm text-black/45">
        <a href={base} class="text-black/45 no-underline transition hover:text-black">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span class="font-medium text-black/70">Contact</span>
      </nav>
    </div>
  </div>

  <!-- Header + Form -->
  <section class="py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-[1fr_1.1fr] lg:gap-16 lg:items-start">
        <!-- Left: Copy + Contact Info -->
        <div>
          <div class="text-sm uppercase tracking-[0.16em] text-black/45">Contact us</div>
          <h1 class="mt-3 text-5xl font-semibold tracking-[-0.03em] text-[#111] sm:text-6xl" style="color: #111;">
            {cms.hero!.headline}
          </h1>
          <p class="mt-6 text-xl leading-8 text-black/64">
            {cms.hero!.subheadline}
          </p>

          <!-- Contact cards -->
          <div class="mt-10 grid gap-4 sm:grid-cols-3">
            <div class="rounded-2xl border border-black/8 bg-[#fbfaf8] p-5 text-center">
              <div class="mx-auto mb-3 flex h-11 w-11 items-center justify-center rounded-xl bg-black/5">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-black/50"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div class="text-xs uppercase tracking-[0.12em] text-black/42">Email</div>
              <a href={`mailto:${cms.email}`} class="mt-1 block text-sm font-medium text-[#111] no-underline hover:underline break-all">{cms.email}</a>
            </div>
            <div class="rounded-2xl border border-black/8 bg-[#fbfaf8] p-5 text-center">
              <div class="mx-auto mb-3 flex h-11 w-11 items-center justify-center rounded-xl bg-black/5">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-black/50"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div class="text-xs uppercase tracking-[0.12em] text-black/42">Phone</div>
              <a href={`tel:${cms.phoneHref}`} class="mt-1 block text-sm font-medium text-[#111] no-underline hover:underline">{cms.phone}</a>
            </div>
            <div class="rounded-2xl border border-black/8 bg-[#fbfaf8] p-5 text-center">
              <div class="mx-auto mb-3 flex h-11 w-11 items-center justify-center rounded-xl bg-black/5">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-black/50"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div class="text-xs uppercase tracking-[0.12em] text-black/42">Hours</div>
              <div class="mt-1 text-sm font-medium text-[#111]">{cms.officeHours}</div>
              <div class="mt-0.5 text-xs text-black/45">{cms.tenantAccess}</div>
            </div>
          </div>
        </div>

        <!-- Right: Form -->
        <div class="rounded-[28px] border border-black/10 bg-white p-6 shadow-[0_18px_50px_rgba(0,0,0,0.06)] lg:p-8">
          <h2 class="text-xl font-semibold tracking-[-0.02em] text-[#111]">Get Availability & Pricing</h2>
          <p class="mt-2 text-sm text-black/55">Tell us what you need. We'll respond within 1 business day.</p>
          <form name="contact" method="POST" data-netlify="true" class="mt-6 grid gap-4">
            <input type="hidden" name="form-name" value="contact" />
            <div class="grid gap-4 sm:grid-cols-2">
              <input type="text" name="name" required placeholder="Your name *" class="h-12 rounded-2xl border border-black/10 bg-[#fbfaf8] px-4 text-black placeholder:text-black/35 focus:outline-none focus:ring-2 focus:ring-black/20" />
              <input type="text" name="business" required placeholder="Business name *" class="h-12 rounded-2xl border border-black/10 bg-[#fbfaf8] px-4 text-black placeholder:text-black/35 focus:outline-none focus:ring-2 focus:ring-black/20" />
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <input type="email" name="email" required placeholder="Email *" class="h-12 rounded-2xl border border-black/10 bg-[#fbfaf8] px-4 text-black placeholder:text-black/35 focus:outline-none focus:ring-2 focus:ring-black/20" />
              <input type="tel" name="phone" required placeholder="Phone *" class="h-12 rounded-2xl border border-black/10 bg-[#fbfaf8] px-4 text-black placeholder:text-black/35 focus:outline-none focus:ring-2 focus:ring-black/20" />
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <select name="size" class="h-12 rounded-2xl border border-black/10 bg-[#fbfaf8] px-4 text-black/55 focus:outline-none focus:ring-2 focus:ring-black/20">
                <option value="">Size needed...</option>
                <option value="1000">~1,000 SF</option>
                <option value="1500">~1,500 SF</option>
                <option value="2000">~2,000 SF</option>
                <option value="2500">~2,500 SF</option>
                <option value="3000">~3,000 SF</option>
              </select>
              <select name="timing" class="h-12 rounded-2xl border border-black/10 bg-[#fbfaf8] px-4 text-black/55 focus:outline-none focus:ring-2 focus:ring-black/20">
                <option value="">Move-in timing...</option>
                <option value="immediately">Immediately</option>
                <option value="30-60">30-60 days</option>
                <option value="60-120">60-120 days</option>
                <option value="120+">120+ days</option>
                <option value="exploring">Just exploring</option>
              </select>
            </div>
            <select name="use-case" class="h-12 rounded-2xl border border-black/10 bg-[#fbfaf8] px-4 text-black/55 focus:outline-none focus:ring-2 focus:ring-black/20">
              <option value="">Intended use...</option>
              <option value="contractor">Contractor / Trades</option>
              <option value="ecommerce">E-Commerce / Fulfillment</option>
              <option value="manufacturing">Light Manufacturing</option>
              <option value="brewery">Brewery / Food Production</option>
              <option value="creative">Creative Studio / Showroom</option>
              <option value="warehouse">General Warehouse</option>
              <option value="other">Other</option>
            </select>
            <textarea name="message" rows="3" placeholder="Anything else we should know? (optional)" class="rounded-2xl border border-black/10 bg-[#fbfaf8] px-4 py-3 text-black placeholder:text-black/35 focus:outline-none focus:ring-2 focus:ring-black/20 resize-none"></textarea>
            <button type="submit" class="h-12 cursor-pointer rounded-2xl bg-black px-6 font-medium text-white transition hover:bg-black/85">
              Get Availability & Pricing
            </button>
            <p class="text-center text-xs text-black/45">No obligation. Direct to leasing team.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

</NewLayout>
