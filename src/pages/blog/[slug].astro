---
import { getCollection, render } from 'astro:content';
import NewLayout from '../../layouts/NewLayout.astro';
import LeadForm from '../../components/LeadForm.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  return allPosts.map(post => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Schema markup for article
const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date,
  author: { '@type': 'Organization', name: post.data.author || 'GetFlexSpace' },
  publisher: { '@type': 'Organization', name: 'GetFlexSpace' },
  ...(post.data.image ? { image: post.data.image } : {}),
});
---

<NewLayout title={`${post.data.title} | GetFlexSpace`} description={post.data.description} schemaMarkup={articleSchema}>
  <!-- Breadcrumb -->
  <div class="bg-[#f7f5f1] border-b border-black/5">
    <div class="mx-auto max-w-7xl px-6 py-3 lg:px-8">
      <nav class="flex items-center gap-2 text-sm text-black/45">
        <a href={base} class="no-underline text-black/45 hover:text-black transition">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <a href={`${base}blog/`} class="no-underline text-black/45 hover:text-black transition">Blog</a>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-black/70 font-medium truncate max-w-[200px]">{post.data.title}</span>
      </nav>
    </div>
  </div>

  <article class="py-14 lg:py-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-[1fr_340px] lg:items-start">
        <!-- Main content -->
        <div class="max-w-3xl">
          <!-- Categories + date -->
          <div class="flex flex-wrap items-center gap-3 mb-6">
            {post.data.categories.map((cat: string) => (
              <a
                href={`${base}blog/category/${cat.toLowerCase().replace(/[^a-z0-9]+/g, '-')}/`}
                class="rounded-full bg-[#fbfaf8] border border-black/10 px-3 py-1 text-xs font-medium text-black/55 no-underline hover:bg-black/5 transition"
              >
                {cat}
              </a>
            ))}
            <span class="text-sm text-black/40">{formattedDate}</span>
          </div>

          <!-- Title -->
          <h1 class="text-3xl font-semibold tracking-[-0.03em] text-[#111] sm:text-4xl lg:text-[2.75rem] leading-[1.1]">
            {post.data.title}
          </h1>

          <!-- Hero image -->
          {post.data.image && (
            <div class="mt-8 overflow-hidden rounded-[20px]">
              <img src={post.data.image} alt={post.data.imageAlt || post.data.title} class="w-full object-cover" loading="eager" />
            </div>
          )}

          <!-- Prose content -->
          <div class="mt-10 prose-blog">
            <Content />
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:sticky lg:top-24">
          <div class="rounded-[28px] border border-black/10 bg-white p-6 shadow-[0_10px_24px_rgba(0,0,0,0.03)]">
            <div class="text-sm uppercase tracking-[0.14em] text-black/45 mb-2">Get availability</div>
            <div class="text-xl font-semibold tracking-[-0.02em] text-[#111] mb-1">
              Looking for space?
            </div>
            <p class="text-sm text-black/55 mb-5">Tell us what you need and we'll respond within 1 business day.</p>
            <LeadForm compact buttonLabel="Get availability" />
          </div>
        </aside>
      </div>
    </div>
  </article>
</NewLayout>

<style is:global>
  .prose-blog {
    color: rgba(0, 0, 0, 0.72);
    line-height: 1.8;
    font-size: 1.0625rem;
  }
  .prose-blog h2 {
    color: #111;
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose-blog h3 {
    color: #111;
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-blog p {
    margin-bottom: 1.25rem;
  }
  .prose-blog ul, .prose-blog ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  .prose-blog li {
    margin-bottom: 0.5rem;
  }
  .prose-blog strong {
    color: #111;
    font-weight: 600;
  }
  .prose-blog a {
    color: #111;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.15s;
  }
  .prose-blog a:hover {
    color: rgba(0, 0, 0, 0.6);
  }
  .prose-blog blockquote {
    border-left: 3px solid rgba(0, 0, 0, 0.15);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: rgba(0, 0, 0, 0.55);
  }
</style>
